def fetch_user_tweets(
    user_id: str,
    token: str,
    *,
    since_dt: dt.datetime | None,
    budget: ReadBudget,
    wall: WallClock,
    hard_cap: int = PER_HANDLE_HARD_CAP,
) -> list[dict]:
    """Pull recent tweets from one user. Returns list of tweet dicts ordered
    newest-first. `since_dt` filters server-side via start_time."""
    params = {
        "max_results": PAGE_SIZE,
        "tweet.fields": "created_at,public_metrics,referenced_tweets,in_reply_to_user_id,entities,conversation_id,author_id,lang",
        "exclude": "retweets",  # exclude pure RTs server-side
    }
    if since_dt:
        params["start_time"] = since_dt.strftime("%Y-%m-%dT%H:%M:%SZ")
    out: list[dict] = []
    for tw, _users in x_paged(f"/users/{user_id}/tweets", token, params,
                              budget=budget, wall=wall):
        out.append(tw)
        if len(out) >= hard_cap:
            info(f"  user {user_id}: hit hard cap {hard_cap}, stopping")
            return out
    return out


def fetch_list_tweets(
    list_id: str,
    token: str,
    *,
    since_id: str | None,
    budget: ReadBudget,
    wall: WallClock,
    hard_cap: int = 1000,
) -> list[tuple[dict, str]]:
    """Pull recent tweets from a list. Returns [(tweet, author_id), ...].
    `since_id` filters client-side (list endpoint doesn't accept since_id).
    IDs compared as ints — Twitter snowflakes aren't lexically sortable across
    length boundaries (e.g., "999..."(19) > "1000..."(20) lexically but not
    numerically)."""
    params = {
        "max_results": PAGE_SIZE,
        "tweet.fields": "created_at,public_metrics,referenced_tweets,in_reply_to_user_id,entities,conversation_id,author_id,lang",
        "expansions": "author_id",
    }
    since_int = int(since_id) if since_id else None
    out: list[tuple[dict, str]] = []
    for tw, _users in x_paged(f"/lists/{list_id}/tweets", token, params,
                              budget=budget, wall=wall):
        author_id = str(tw.get("author_id") or "")
        if since_int is not None and tw.get("id") and int(tw["id"]) <= since_int:
            return out
        out.append((tw, author_id))
        if len(out) >= hard_cap:
            return out
    return out


def list_create(token: str, name: str, description: str = "") -> str:
    """Create a private list and return its id."""
    status, data = x_request("POST", "/lists", token,
                             body={"name": name, "description": description,
                                   "private": True})
    lid = ((data.get("data") or {}).get("id"))
    if not lid:
        raise XServerError(f"list_create: unexpected response: {data}")
    return str(lid)


def list_add_member(token: str, list_id: str, user_id: str) -> None:
    x_request("POST", f"/lists/{list_id}/members", token,
              body={"user_id": str(user_id)})


def list_remove_member(token: str, list_id: str, user_id: str) -> None:
    x_request("DELETE", f"/lists/{list_id}/members/{user_id}", token)


def list_members(token: str, list_id: str, *, budget: ReadBudget,
                 wall: WallClock) -> dict[str, dict]:
    """Return {user_id: user_obj} for all current List members."""
    out: dict[str, dict] = {}
    pagination: str | None = None
    while True:
        params = {"max_results": 100, "user.fields": "username"}
        if pagination:
            params["pagination_token"] = pagination
        _status, data = x_request("GET", f"/lists/{list_id}/members", token,
                                  params=params, budget=budget, wall=wall)
        for u in (data.get("data") or []):
            uid = str(u.get("id"))
            if uid:
                out[uid] = u
        meta = data.get("meta") or {}
        pagination = meta.get("next_token")
        if not pagination:
            return out


# ─── Setup: create the private List ──────────────────────────────────────────


def cmd_setup(wl: Watchlist, token: str, *, dry_run: bool) -> None:
    if wl.list_id:
        info(f"list_id already set: {wl.list_id}; skipping create.")
        return
    name = "erv-electrification-watchlist"
    desc = "Private List for x-ingest. Auto-managed; edit ~/bin/config/x-watchlist.json."
    if dry_run:
        info(f"[dry-run] would create private list {name!r} with {len(wl.accounts)} members")
        return
    list_id = list_create(token, name, desc)
    info(f"created private list: {list_id}")
    # Save list_id BEFORE adding members. If credits deplete mid-add, the
    # auto-reconcile path on the next run will retry the missing adds against
    # this same list — no orphan-list created.
    save_watchlist_list_id(wl, list_id)
    info(f"wrote list_id back to {CONFIG_PATH}")
    for acct in wl.accounts:
        try:
            list_add_member(token, list_id, acct.user_id)
            info(f"  + @{acct.handle} ({acct.user_id})")
        except XServerError as e:
            info(f"  ! @{acct.handle}: {e}")


LIST_ADD_RETRY_COOLDOWN_DAYS = 7


def reconcile_list(wl: Watchlist, token: str, state: dict, *,
                   budget: ReadBudget, wall: WallClock,
                   fix: bool) -> tuple[set[str], set[str]]:
    """Diff list members vs watchlist.

    Returns (extra_in_list, missing_from_list). If `fix=True`, the diff is
    applied: extras are removed from the List, missing are added.

    Failed list_add_member calls are tracked in state.list_add_failures and
    skipped for LIST_ADD_RETRY_COOLDOWN_DAYS to avoid retrying dead/suspended
    accounts on every run.
    """
    if not wl.list_id:
        return set(), set()
    members = list_members(token, wl.list_id, budget=budget, wall=wall)
    want_ids = {a.user_id for a in wl.accounts}
    have_ids = set(members.keys())
    extras = have_ids - want_ids
    missing = want_ids - have_ids
    if extras or missing:
        info(f"  list reconcile: +{len(missing)} missing, -{len(extras)} extras")
    if fix:
        failures: dict[str, dict] = state.get("list_add_failures") or {}
        today = dt.date.today()
        cooldown = dt.timedelta(days=LIST_ADD_RETRY_COOLDOWN_DAYS)
        for uid in extras:
            try:
                list_remove_member(token, wl.list_id, uid)
                info(f"  -list @{members[uid].get('username', uid)}")
            except XServerError as e:
                info(f"  ! list remove {uid}: {e}")
        for uid in missing:
            prev = failures.get(uid)
            if prev:
                try:
                    last_try = dt.date.fromisoformat(prev["tried_at"][:10])
                    if today - last_try < cooldown:
                        info(f"  ~list {uid}: in cooldown ({prev['last_err'][:60]})")
                        continue
                except (KeyError, ValueError):
                    pass
            try:
                list_add_member(token, wl.list_id, uid)
                info(f"  +list {uid}")
                failures.pop(uid, None)
            except XServerError as e:
                info(f"  ! list add {uid}: {e}")
                failures[uid] = {"last_err": str(e)[:300], "tried_at": now_iso()}
        state["list_add_failures"] = failures
    return extras, missing


