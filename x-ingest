# ─── Two-write transactional ──────────────────────────────────────────────────


def two_write(
    tw: dict,
    acct: WatchAccount,
    filter_meta: dict,
    *,
    dry_run: bool = False,
) -> tuple[bool, str]:
    """Write signal page + append to people timeline atomically.

    Returns (committed, status). Committed=True means cursor may advance.
    Failed people-write enqueues to reconcile but still counts as committed
    (signal page is on disk; we don't want to re-fetch and re-write the same
    signal page on every retry).
    """
    metrics = tweet_metrics(tw)
    fm, body = render_signal_page(tw, acct, filter_meta, metrics)
    try:
        created = parse_iso(tw.get("created_at") or now_iso())
    except ValueError:
        created = dt.datetime.now(dt.timezone.utc)
    sig_path = signal_page_path(acct.handle, str(tw.get("id")), created)
    if dry_run:
        info(f"  [dry-run] would write {sig_path.relative_to(BRAIN)}")
        return True, "dry-run"

    if not sig_path.is_file():
        write_signal_page_atomic(sig_path, fm, body)

    # People-page append. ALWAYS attempted, even when signal page already
    # exists — append_to_people_timeline is idempotent (line-level dedup), so
    # this self-heals crash-between-writes where a prior run wrote the signal
    # but failed before completing the timeline append.
    people_path = find_existing_people_page(acct)
    if people_path:
        timeline_line = render_people_timeline_line(tw, acct)
        try:
            append_to_people_timeline(people_path, timeline_line)
            return True, "signal+timeline"
        except XWriteError as e:
            enqueue_reconcile({
                "user_id": acct.user_id,
                "handle": acct.handle,
                "post_id": str(tw.get("id")),
                "people_path": str(people_path),
                "timeline_line": timeline_line,
                "error": str(e),
                "queued_at": now_iso(),
            })
            return True, f"signal-only-reconcile-queued ({e})"
    else:
        return True, "signal-only-no-people-page"


# ─── Backfill ─────────────────────────────────────────────────────────────────


def cmd_backfill(
    wl: Watchlist,
    token: str,
    state: dict,
    *,
    budget: ReadBudget,
    wall: WallClock,
    dry_run: bool,
    limit: int | None,
    tier_filter: int | None,
) -> dict:
    """Run per-handle backfill across the watchlist. Resumes from per_handle_cursor."""
    watchlist_uids = {a.user_id for a in wl.accounts}
    stats = {
        "fetched": 0, "signals": 0, "skipped": 0, "errors": 0,
        "narratives": 0, "handles_done": 0,
    }
    stdout_contract(f"RUN_START:{now_iso()}:mode=backfill")
    narrative_buckets: dict[str, list[tuple[dict, list[str]]]] = defaultdict(list)

    for acct in wl.accounts:
        if tier_filter and acct.tier != tier_filter:
            continue
        if state["per_handle_done"].get(acct.user_id) and not dry_run:
            info(f"@{acct.handle}: already complete, skip")
            continue
        days = BACKFILL_DAYS[acct.tier]
        since = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=days)
        info(f"@{acct.handle} (T{acct.tier}): backfill {days}d since {since.date()}")
        try:
            tweets = fetch_user_tweets(acct.user_id, token, since_dt=since,
                                       budget=budget, wall=wall,
                                       hard_cap=hard_cap_for_tier(acct.tier))
        except XCreditsDepletedError:
            raise
        except XRateLimitError as e:
            info(f"  rate-limited; saving state and exiting: {e}")
            break
        except XServerError as e:
            info(f"  @{acct.handle}: {e}; skipping")
            stats["errors"] += 1
            continue
        stats["fetched"] += len(tweets)
        baseline = author_baseline_from_tweets(tweets)
        info(f"  fetched {len(tweets)} tweets; baseline n={(baseline.n if baseline else 0)}")

        # Track newest tweet seen so delta-after-backfill knows where to resume.
        newest_int: int | None = None
        newest_id: str | None = None
        for tw in tweets:
            tid = str(tw.get("id"))
            try:
                tid_int = int(tid)
            except ValueError:
                tid_int = None
            if tid_int is not None and (newest_int is None or tid_int > newest_int):
                newest_int = tid_int
                newest_id = tid
            ok, meta = passes_signal_filter(tw, acct, baseline, watchlist_uids)
            if not ok:
                stats["skipped"] += 1
                continue
            committed, status = two_write(tw, acct, meta, dry_run=dry_run)
            if committed:
                stats["signals"] += 1
                kws = meta.get("keywords") or []
                narrative_buckets[acct.user_id].append((tw, kws))
            if limit and stats["signals"] >= limit:
                info(f"  hit --limit {limit}, stopping backfill")
                if newest_id and not dry_run:
                    state["per_handle_cursor"][acct.user_id] = newest_id
                _maybe_finalize(stats, state, narrative_buckets, dry_run)
                return stats
        if newest_id and not dry_run:
            state["per_handle_cursor"][acct.user_id] = newest_id
        state["per_handle_done"][acct.user_id] = True
        stats["handles_done"] += 1
        stdout_contract(f"HANDLE_DONE:{acct.handle}:fetched={len(tweets)}:signals={stats['signals']}")

    # backfill_complete reflects WHOLE watchlist coverage, not just the
    # filtered tier. A --tier 1 run that completes T1 must not flip the flag
    # while T2/T3 remain un-baselined.
    if all(state["per_handle_done"].get(a.user_id) for a in wl.accounts):
        state["backfill_complete"] = True

    _maybe_finalize(stats, state, narrative_buckets, dry_run)
    return stats


def _maybe_finalize(
    stats: dict,
    state: dict,
    narrative_buckets: dict[str, list[tuple[dict, list[str]]]],
    dry_run: bool,
) -> None:
    """Compute narrative alerts and update state. Rare-keyword frequency is
    computed across ALL handles' weekly posts (cross-handle denominator) so
    that "rare" reflects watchlist-wide novelty, not single-handle novelty."""
    all_posts: list[tuple[dict, list[str]]] = []
    for posts in narrative_buckets.values():
        all_posts.extend(posts)
    rare = compute_rare_keywords(all_posts)
    for uid, week_posts in narrative_buckets.items():
        topic = narrative_alert(uid, week_posts, rare)
        if topic:
            stats["narratives"] += 1
            stdout_contract(f"NARRATIVE_ALERT:user_id={uid}:topic={topic}:count={len(week_posts)}")
            if not dry_run:
                _annotate_narrative(uid, topic, len(week_posts), state)
    state["last_run_at"] = now_iso()
    state["reads_total"] = state.get("reads_total", 0) + stats["fetched"]


def _annotate_narrative(uid: str, topic: str, count: int, state: dict) -> None:
    """Track narrative annotations in state with 90d TTL."""
    entries = state["narrative_counters"].setdefault(uid, [])
    expires = (dt.datetime.now(dt.timezone.utc)
               + dt.timedelta(days=NARRATIVE_ANNOTATION_TTL_DAYS)).strftime("%Y-%m-%d")
    entries.append({
        "topic": topic, "count": count, "detected": today_iso(),
        "expires": expires,
    })


def cleanup_expired_narratives(state: dict) -> int:
    """Drop narrative annotations past their TTL. Returns count removed."""
    removed = 0
    today = today_iso()
    for uid, entries in list(state["narrative_counters"].items()):
        kept = [e for e in entries if e.get("expires", "") >= today]
        removed += len(entries) - len(kept)
        if kept:
            state["narrative_counters"][uid] = kept
        else:
            del state["narrative_counters"][uid]
    return removed


# ─── Delta sync ───────────────────────────────────────────────────────────────


def cmd_delta(
    wl: Watchlist,
    token: str,
    state: dict,
    *,
    budget: ReadBudget,
    wall: WallClock,
    dry_run: bool,
    limit: int | None,
) -> dict:
    """Weekly delta: pull recent tweets from the X List; per-handle fallback."""
    if not state.get("backfill_complete"):
        info("WARN: backfill not complete; delta may be sparse on un-baselined accounts.")
    watchlist_uids = {a.user_id for a in wl.accounts}
    by_uid = wl.by_user_id()
    stats = {"fetched": 0, "signals": 0, "skipped": 0, "errors": 0, "narratives": 0}
    stdout_contract(f"RUN_START:{now_iso()}:mode=delta")

    narrative_buckets: dict[str, list[tuple[dict, list[str]]]] = defaultdict(list)

    use_list = bool(wl.list_id)
    list_failed = False
    if use_list:
        try:
            info(f"delta via list {wl.list_id} (since_id={state.get('list_cursor')})")
            results = fetch_list_tweets(wl.list_id, token,
                                        since_id=state.get("list_cursor"),
                                        budget=budget, wall=wall)
            stats["fetched"] = len(results)
            # Snowflake IDs compared as ints (lex compare breaks across
            # length boundaries).
            max_id = state.get("list_cursor")
            max_id_int = int(max_id) if max_id else None
            for tw, author_id in results:
                tid = str(tw.get("id"))
                tid_int = int(tid)
                if max_id_int is None or tid_int > max_id_int:
                    max_id = tid
                    max_id_int = tid_int
                acct = by_uid.get(author_id)
                if not acct:
                    # Author not in our watchlist (e.g., list contains extras).
                    stats["skipped"] += 1
                    continue
                ok, meta = passes_signal_filter(tw, acct, None, watchlist_uids)
                # No baseline available in delta mode unless we maintain one.
                # (Per design: baselines computed during backfill; in delta we
                # use absolute thresholds.)
                if not ok:
                    stats["skipped"] += 1
                    continue
                committed, status = two_write(tw, acct, meta, dry_run=dry_run)
                if committed:
                    stats["signals"] += 1
                    kws = meta.get("keywords") or []
                    narrative_buckets[acct.user_id].append((tw, kws))
                if limit and stats["signals"] >= limit:
                    break
            if max_id:
                state["list_cursor"] = max_id
        except XServerError as e:
            info(f"list endpoint failed: {e}; falling back to per-handle delta")
            list_failed = True
        except XRateLimitError as e:
            info(f"rate-limited on list endpoint: {e}; saving state and exiting")
            list_failed = True

    if not use_list or list_failed:
        # Per-handle delta: only fetch tweets newer than per_handle_cursor.
        for acct in wl.accounts:
            cursor_id = state["per_handle_cursor"].get(acct.user_id)
            since = None
            if not cursor_id:
                # First delta after backfill — only pull last 3 days to bridge gap.
                since = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=3)
            try:
                tweets = fetch_user_tweets(acct.user_id, token, since_dt=since,
                                           budget=budget, wall=wall)
            except XCreditsDepletedError:
                raise
            except XServerError as e:
                stats["errors"] += 1
                info(f"  @{acct.handle}: {e}; skip")
                continue
            stats["fetched"] += len(tweets)
            new_cursor = cursor_id
            cursor_int = int(cursor_id) if cursor_id else None
            new_cursor_int = cursor_int
            for tw in tweets:
                tid = str(tw.get("id"))
                tid_int = int(tid)
                if cursor_int is not None and tid_int <= cursor_int:
                    continue
                if new_cursor_int is None or tid_int > new_cursor_int:
                    new_cursor = tid
                    new_cursor_int = tid_int
                ok, meta = passes_signal_filter(tw, acct, None, watchlist_uids)
                if not ok:
                    stats["skipped"] += 1
                    continue
                committed, _ = two_write(tw, acct, meta, dry_run=dry_run)
                if committed:
                    stats["signals"] += 1
                    kws = meta.get("keywords") or []
                    narrative_buckets[acct.user_id].append((tw, kws))
            if new_cursor:
                state["per_handle_cursor"][acct.user_id] = new_cursor
            stdout_contract(f"HANDLE_DONE:{acct.handle}:fetched={len(tweets)}")

    _maybe_finalize(stats, state, narrative_buckets, dry_run)
    return stats


# ─── Stats mode (estimate without ingesting) ──────────────────────────────────


def cmd_stats(wl: Watchlist, token: str, *, budget: ReadBudget,
              wall: WallClock) -> None:
    """Estimate backfill volume per handle without writing anything."""
    info("Estimating backfill volume per handle (one fetch per account)...")
    grand_total = 0
    by_tier: dict[int, int] = defaultdict(int)
    for acct in wl.accounts:
        days = BACKFILL_DAYS[acct.tier]
        since = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=days)
        try:
            tweets = fetch_user_tweets(acct.user_id, token, since_dt=since,
                                       budget=budget, wall=wall,
                                       hard_cap=hard_cap_for_tier(acct.tier))
        except XServerError as e:
            info(f"  @{acct.handle}: {e}")
            continue
        watchlist_uids = {a.user_id for a in wl.accounts}
        baseline = author_baseline_from_tweets(tweets)
        signals = 0
        for tw in tweets:
            ok, _ = passes_signal_filter(tw, acct, baseline, watchlist_uids)
            if ok:
                signals += 1
        info(f"  @{acct.handle} (T{acct.tier}, {days}d): {len(tweets)} fetched, "
             f"{signals} pass filter, baseline_n={baseline.n if baseline else 0}")
        grand_total += signals
        by_tier[acct.tier] += signals
    info(f"\nESTIMATE: {grand_total} signal pages total")
    for t in (1, 2, 3):
        info(f"  Tier {t}: {by_tier[t]} signals")
    info(f"  API reads consumed (estimate): {budget.used}")


# ─── Index regeneration ───────────────────────────────────────────────────────


def regenerate_signal_index(
    wl: Watchlist,
    state: dict,
    *,
    partial: bool,
) -> Path:
    """Rebuild ~/brain/concepts/x-signal-index.md.

    If partial=True (backfill not complete), writes to x-signal-index-partial.md
    with a banner.
    """
    CONCEPTS_DIR.mkdir(parents=True, exist_ok=True)
    name = "x-signal-index-partial.md" if partial else "x-signal-index.md"
    path = CONCEPTS_DIR / name
    now = dt.datetime.now(dt.timezone.utc)
    week_ago = now - dt.timedelta(days=7)

    handle_counts: dict[str, int] = defaultdict(int)
    handle_topics: dict[str, dict[str, int]] = defaultdict(lambda: defaultdict(int))
    handle_latest: dict[str, str] = {}
    total_week = 0

    if SIGNALS_DIR.is_dir():
        for sub in SIGNALS_DIR.iterdir():
            if not sub.is_dir():
                continue
            for p in sub.glob("*.md"):
                try:
                    with p.open("r") as f:
                        head = f.read(2048)
                except OSError:
                    continue
                m = re.search(r"^date:\s*(\d{4}-\d{2}-\d{2})", head, re.MULTILINE)
                if not m:
                    continue
                try:
                    d = dt.datetime.fromisoformat(m.group(1)).replace(tzinfo=dt.timezone.utc)
                except ValueError:
                    continue
                if d < week_ago:
                    continue
                handle_m = re.search(r"^handle:\s*(\S+)", head, re.MULTILINE)
                if not handle_m:
                    continue
                handle = handle_m.group(1)
                handle_counts[handle] += 1
                total_week += 1
                if (handle not in handle_latest) or (m.group(1) > handle_latest[handle]):
                    handle_latest[handle] = m.group(1)
                kw_m = re.search(r"thesis_relevance:\s*\[([^\]]*)\]", head)
                if kw_m:
                    for kw in [s.strip() for s in kw_m.group(1).split(",") if s.strip()]:
                        handle_topics[handle][kw] += 1

    by_uid = wl.by_user_id()
    handle_to_tier: dict[str, int] = {a.handle: a.tier for a in wl.accounts}

    out = ["# X Signal Index", ""]
    if partial:
        out += ["> **STILL BACKFILLING** — this is a partial index. The full index"
                " regenerates after backfill completes.", ""]
    out += [f"Last synced: {now.strftime('%Y-%m-%d %H:%M')} UTC", ""]
    out += ["## Most active this week (by thesis-relevant post count)", ""]
    out += ["| Handle | Tier | Posts | Top topic | Latest |",
            "|---|---|---|---|---|"]
    for handle, count in sorted(handle_counts.items(), key=lambda kv: -kv[1])[:15]:
        tops = handle_topics[handle]
        top_kw = max(tops.items(), key=lambda kv: kv[1])[0] if tops else "—"
        out.append(f"| [[@{handle}]] | T{handle_to_tier.get(handle, '?')} | "
                   f"{count} | {top_kw} | {handle_latest.get(handle, '—')} |")
    out += ["", "## Narrative alerts (3+ posts on same topic, 7d)", ""]
    any_alert = False
    for uid, entries in (state.get("narrative_counters") or {}).items():
        acct = by_uid.get(uid)
        if not acct:
            continue
        for e in entries:
            if e.get("expires", "") < today_iso():
                continue
            any_alert = True
            out.append(f"- **@{acct.handle}** (T{acct.tier}): {e.get('count','?')}"
                       f" posts on `{e.get('topic','?')}` (detected {e.get('detected','?')},"
                       f" expires {e.get('expires','?')})")
    if not any_alert:
        out.append("_no active narrative alerts_")
    out += ["", "## Watchlist coverage", ""]
    tcounts = defaultdict(int)
    for h in handle_counts:
        tcounts[handle_to_tier.get(h, "?")] += 1
    for t in (1, 2, 3):
        accs = [a for a in wl.accounts if a.tier == t]
        out.append(f"- Tier {t}: {tcounts[t]} of {len(accs)} accounts posted; "
                   f"{sum(handle_counts[a.handle] for a in accs)} signals this week")
    out += ["", "## Total signals this week", "", f"{total_week}", ""]

    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text("\n".join(out))
    tmp.replace(path)
    return path


# ─── Heartbeat + run summary ──────────────────────────────────────────────────


def write_heartbeat(event: str, status: str, **details: Any) -> None:
    INTEGRATION_DIR.mkdir(parents=True, exist_ok=True)
    rec = {"ts": now_iso(), "event": event, "source_version": "0.1",
           "status": status, "details": details}
    try:
        with HEARTBEAT_PATH.open("a") as f:
            f.write(json.dumps(rec, default=str) + "\n")
    except OSError:
        pass


def write_run_summary(mode: str, stats: dict, state: dict, started_at: str,
                      ended_at: str, reads_used: int,
                      reconcile_q_size: int) -> Path:
    TASKS_DIR.mkdir(parents=True, exist_ok=True)
    fname = f"x-run-{dt.datetime.now().strftime('%Y-%m-%d-%H%M')}.md"
    path = TASKS_DIR / fname
    lines = [
        f"# x-ingest run — {mode}",
        "",
        f"- started: {started_at}",
        f"- ended: {ended_at}",
        f"- reads_used: {reads_used}",
        f"- backfill_complete: {state.get('backfill_complete')}",
        f"- signals_total_run: {stats.get('signals', 0)}",
        f"- fetched_total_run: {stats.get('fetched', 0)}",
        f"- skipped_total_run: {stats.get('skipped', 0)}",
        f"- errors: {stats.get('errors', 0)}",
        f"- narratives_detected: {stats.get('narratives', 0)}",
        f"- reconcile_queue_size: {reconcile_q_size}",
        "",
    ]
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text("\n".join(lines))
    tmp.replace(path)
    return path


def reconcile_queue_size() -> int:
    if not RECONCILE_DIR.is_dir():
        return 0
    return len(list(RECONCILE_DIR.glob("*.json")))


# ─── CLI ──────────────────────────────────────────────────────────────────────


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(description="x-ingest — X watchlist to brain signal collector")
    mode = p.add_mutually_exclusive_group()
    mode.add_argument("--backfill", action="store_true", help="Per-handle tiered-window backfill")
    mode.add_argument("--delta", action="store_true", help="Default: list-based delta sync")
    mode.add_argument("--setup", action="store_true", help="Create the private X List")
    mode.add_argument("--stats", action="store_true", help="Estimate volume; no writes")
    mode.add_argument("--reconcile-list", action="store_true",
                      help="Diff List vs watchlist and apply fixes")
    p.add_argument("--dry-run", action="store_true", help="No writes, no state changes")
    p.add_argument("--limit", type=int, default=None, help="Stop after N signals written")
    p.add_argument("--tier", type=int, choices=[1, 2, 3], default=None,
                   help="Backfill only one tier")
    p.add_argument("--max-reads", type=int, default=DEFAULT_MAX_READS,
                   help=f"API read budget (default {DEFAULT_MAX_READS})")
    p.add_argument("--no-index", action="store_true", help="Skip index regeneration")
    args = p.parse_args(argv)

    started_at = now_iso()
    info(f"x-ingest start: {started_at}")

    try:
        wl = load_watchlist()
    except XConfigError as e:
        info(f"FATAL: {e}")
        write_heartbeat("run", "config_error", error=str(e))
        return 78

    info(f"watchlist: {len(wl.accounts)} accounts, list_id={wl.list_id}")

    try:
        token = load_bearer_token()
    except XAuthMissingError as e:
        info(f"FATAL: {e}")
        write_heartbeat("run", "auth_missing", error=str(e))
        return 78

    budget = ReadBudget(max_reads=args.max_reads)
    wall = WallClock()

    state = load_state()
    n_expired = cleanup_expired_narratives(state)
    if n_expired:
        info(f"  expired {n_expired} narrative annotations")

    try:
        with acquire_lock():
            if args.setup:
                cmd_setup(wl, token, dry_run=args.dry_run)
                write_heartbeat("setup", "ok", list_id=wl.list_id)
                return 0

            if args.reconcile_list:
                extras, missing = reconcile_list(wl, token, state, budget=budget,
                                                  wall=wall, fix=not args.dry_run)
                info(f"reconcile: extras={len(extras)}, missing={len(missing)}")
                return 0

            if args.stats:
                cmd_stats(wl, token, budget=budget, wall=wall)
                return 0

            # Auto-reconcile list (read-only check) on every real run.
            if wl.list_id and not args.dry_run:
                try:
                    reconcile_list(wl, token, state, budget=budget, wall=wall, fix=True)
                except XServerError as e:
                    info(f"list reconcile warning: {e}")

            if args.backfill:
                stats = cmd_backfill(wl, token, state, budget=budget, wall=wall,
                                     dry_run=args.dry_run, limit=args.limit,
                                     tier_filter=args.tier)
            else:
                # Default: delta
                stats = cmd_delta(wl, token, state, budget=budget, wall=wall,
                                  dry_run=args.dry_run, limit=args.limit)

            if not args.dry_run:
                save_state_atomic(state)

            if not args.no_index:
                idx_path = regenerate_signal_index(
                    wl, state, partial=not state.get("backfill_complete"))
                info(f"signal index: {idx_path}")

            ended_at = now_iso()
            summary_path = write_run_summary(
                "backfill" if args.backfill else "delta", stats, state,
                started_at, ended_at, budget.used, reconcile_queue_size())
            info(f"run summary: {summary_path}")
            stdout_contract(
                f"RUN_COMPLETE:{ended_at}:reads={budget.used}"
                f":signals={stats.get('signals',0)}"
                f":narratives={stats.get('narratives',0)}"
            )
            write_heartbeat("run", "ok", reads=budget.used,
                            signals=stats.get('signals', 0),
                            narratives=stats.get('narratives', 0),
                            backfill_complete=state.get('backfill_complete'))
            return 0

    except XAuthError as e:
        info(f"FATAL AUTH: {e}")
        write_heartbeat("run", "auth_error", error=str(e))
        return 78
    except XCreditsDepletedError as e:
        info(f"FATAL CREDITS: {e}")
        write_heartbeat("run", "credits_depleted", error=str(e))
        return 78
    except XReadBudgetExhausted as e:
        info(f"BUDGET EXHAUSTED: {e}")
        write_heartbeat("run", "budget_exhausted", error=str(e))
        # Still save state and return non-zero so cron knows partial.
        try:
            save_state_atomic(state)
        except OSError:
            pass
        return 75
    except XWallClockExceeded as e:
        info(f"WALL CLOCK: {e}")
        write_heartbeat("run", "wall_clock", error=str(e))
        try:
            save_state_atomic(state)
        except OSError:
            pass
        return 75
    except XLockHeldError as e:
        info(f"LOCK: {e}")
        return 75
    except XConfigError as e:
        info(f"CONFIG: {e}")
        return 78


if __name__ == "__main__":
    sys.exit(main())
