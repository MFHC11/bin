# Schema:
# {
#   "schema_version": 1,
#   "last_run_at": "...",
#   "backfill_complete": false,
#   "per_handle_cursor": {"<user_id>": "<oldest_seen_post_id>"},
#   "per_handle_done": {"<user_id>": true},   # backfill window covered
#   "list_cursor": "<last_seen_post_id>",
#   "rate_limit_snapshot": {"endpoint": {"remaining": int, "reset": int}},
#   "narrative_counters": {"<user_id>": [{"week": "YYYY-WW", "kw": [...], "ids":[...]}]},
#   "reads_total": 0
# }


_STATE_DEFAULTS: dict[str, Any] = {
    "schema_version": 1,
    "last_run_at": None,
    "backfill_complete": False,
    "per_handle_cursor": {},
    "per_handle_done": {},
    "list_cursor": None,
    "rate_limit_snapshot": {},
    "narrative_counters": {},
    "list_add_failures": {},
    "reads_total": 0,
}


def load_state() -> dict:
    if not STATE_PATH.is_file():
        return dict(_STATE_DEFAULTS)
    try:
        loaded = json.loads(STATE_PATH.read_text())
    except json.JSONDecodeError as e:
        raise XConfigError(
            f"state.json corrupt: {e}; refusing partial run. "
            f"Delete {STATE_PATH} to reset (loses cursors)."
        )
    if not isinstance(loaded, dict):
        raise XConfigError("state.json root is not an object")
    schema = loaded.get("schema_version", 1)
    if schema != 1:
        raise XConfigError(f"unsupported state.json schema_version={schema!r}")
    # Forward-compat: merge with defaults so older state files that predate a
    # new key don't blow up on KeyError mid-run.
    merged = dict(_STATE_DEFAULTS)
    merged.update(loaded)
    return merged


def save_state_atomic(state: dict) -> None:
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = STATE_PATH.with_suffix(STATE_PATH.suffix + ".tmp")
    tmp.write_text(json.dumps(state, indent=2) + "\n")
    tmp.replace(STATE_PATH)


# ─── Lock ─────────────────────────────────────────────────────────────────────


@contextmanager
def acquire_lock() -> Iterator[None]:
    BIN_DIR.mkdir(parents=True, exist_ok=True)
    if LOCK_PATH.exists():
        try:
            other_pid = int(LOCK_PATH.read_text().strip())
            os.kill(other_pid, 0)
            raise XLockHeldError(f"another x-ingest is running (pid {other_pid})")
        except (ValueError, ProcessLookupError, PermissionError):
            info(f"  stale lock {LOCK_PATH}; removing")
            try:
                LOCK_PATH.unlink()
            except OSError:
                pass
    LOCK_PATH.write_text(str(os.getpid()) + "\n")
    try:
        yield
    finally:
        try:
            LOCK_PATH.unlink()
        except OSError:
            pass


# ─── Tweet shape helpers ──────────────────────────────────────────────────────


def tweet_is_retweet(tw: dict) -> bool:
    """True only for plain retweets (RT @... without comment)."""
    for ref in tw.get("referenced_tweets") or []:
        if ref.get("type") == "retweeted":
            return True
    # Heuristic: starts with "RT @"
    txt = (tw.get("text") or "").lstrip()
    return txt.startswith("RT @")


def tweet_is_quote(tw: dict) -> bool:
    for ref in tw.get("referenced_tweets") or []:
        if ref.get("type") == "quoted":
            return True
    return False


def tweet_is_reply(tw: dict) -> bool:
    for ref in tw.get("referenced_tweets") or []:
        if ref.get("type") == "replied_to":
            return True
    return tw.get("in_reply_to_user_id") is not None


def tweet_is_thread_starter(tw: dict, author_id: str) -> bool:
    """Heuristic: tweet not in reply to anyone, or replying only to self."""
    if not tweet_is_reply(tw):
        return True
    parent_uid = tw.get("in_reply_to_user_id")
    return parent_uid == author_id


def tweet_metrics(tw: dict) -> dict[str, int]:
    """Returns {likes, replies, retweets, quotes, bookmarks, impressions}.
    Defaults all to 0 if public_metrics is missing (handles protected/edge cases
    per adversarial review #2 KeyError gap)."""
    m = tw.get("public_metrics") or {}
    return {
        "likes": int(m.get("like_count", 0) or 0),
        "replies": int(m.get("reply_count", 0) or 0),
        "retweets": int(m.get("retweet_count", 0) or 0),
        "quotes": int(m.get("quote_count", 0) or 0),
        "bookmarks": int(m.get("bookmark_count", 0) or 0),
        "impressions": int(m.get("impression_count", 0) or 0),
    }


def engagement_score(tw: dict) -> int:
    m = tweet_metrics(tw)
    return m["likes"] + m["replies"] + m["retweets"] + m["quotes"]


def tweet_mentions(tw: dict) -> list[str]:
    """Return mentioned user_ids from the entities block (numeric strings)."""
    out: list[str] = []
    for u in (tw.get("entities") or {}).get("mentions") or []:
        uid = u.get("id")
        if uid:
            out.append(str(uid))
    return out


# ─── Signal filter ────────────────────────────────────────────────────────────


def extract_matched_keywords(text: str) -> list[str]:
    """Return the THESIS_KEYWORDS that match. Lowercased canonical form."""
    out: list[str] = []
    for kw, pat in _KW_PATTERNS:
        if pat.search(text):
            out.append(kw)
    return out


@dataclasses.dataclass
class AuthorBaseline:
    n: int
    median: float
    iqr: float  # inter-quartile range (q3 - q1). 1.349 ≈ IQR/σ for normal.

    def robust_z(self, x: float) -> float:
        if self.iqr <= 0:
            return 0.0
        return (x - self.median) / (self.iqr / 1.349)


def author_baseline_from_tweets(tweets: list[dict]) -> AuthorBaseline | None:
    """Compute robust z-score baseline from this author's recent tweets.
    Returns None if fewer than Z_SCORE_MIN_SAMPLES qualifying entries exist."""
    samples: list[int] = []
    for tw in tweets:
        if tweet_is_retweet(tw):
            continue  # exclude pure retweets — inherit halo, distort baseline
        m = tweet_metrics(tw)
        samples.append(m["likes"])
    if len(samples) < Z_SCORE_MIN_SAMPLES:
        return None
    samples.sort()
    n = len(samples)
    median = statistics.median(samples)
    q1 = samples[n // 4]
    q3 = samples[(3 * n) // 4]
    iqr = float(q3 - q1)
    return AuthorBaseline(n=n, median=float(median), iqr=iqr)


def passes_engagement_gate(
    tw: dict,
    acct: WatchAccount,
    baseline: AuthorBaseline | None,
) -> tuple[bool, str]:
    """Returns (passes, reason). Reason recorded in signal frontmatter."""
    if acct.tier == 1:
        return True, "tier1-any"
    m = tweet_metrics(tw)
    if baseline:
        z = baseline.robust_z(m["likes"])
        if z >= Z_SCORE_THRESHOLD:
            return True, f"zscore={z:.2f}"
        return False, f"zscore={z:.2f}<{Z_SCORE_THRESHOLD}"
    # Fallback: absolute thresholds.
    likes_floor, replies_floor = ENGAGEMENT_FLOOR[acct.tier]
    if likes_floor and m["likes"] >= likes_floor:
        return True, f"likes={m['likes']}>={likes_floor}"
    if replies_floor and m["replies"] >= replies_floor:
        return True, f"replies={m['replies']}>={replies_floor}"
    return False, f"abs-floor likes={m['likes']} replies={m['replies']}"


def passes_signal_filter(
    tw: dict,
    acct: WatchAccount,
    baseline: AuthorBaseline | None,
    watchlist_user_ids: set[str],
) -> tuple[bool, dict]:
    """Decide whether this tweet becomes a signal page.

    Pure retweets are always excluded. Otherwise:
      - keyword match required
      - AND (engagement gate passes OR is thread-starter T1 OR mentions another
        watchlist account)
    Returns (passes, reasons_dict).
    """
    if tweet_is_retweet(tw):
        return False, {"skip": "retweet"}
    text = tw.get("text") or ""
    kws = extract_matched_keywords(text)
    if not kws:
        return False, {"skip": "no-keywords"}
    eng_ok, eng_reason = passes_engagement_gate(tw, acct, baseline)
    is_thread = (acct.tier == 1) and tweet_is_thread_starter(tw, acct.user_id)
    mentions_watch = bool(set(tweet_mentions(tw)) & watchlist_user_ids)
    if eng_ok or is_thread or mentions_watch:
        return True, {
            "keywords": kws,
            "engagement_reason": eng_reason,
            "thread_starter": is_thread,
            "mentions_watchlist": mentions_watch,
            "baseline_n": baseline.n if baseline else 0,
        }
    return False, {"skip": "engagement-gate", "engagement_reason": eng_reason,
                   "keywords": kws}


# ─── Narrative tracking ───────────────────────────────────────────────────────


def iso_week(d: dt.date) -> str:
    y, w, _ = d.isocalendar()
    return f"{y}-W{w:02d}"


def compute_rare_keywords(
    week_posts: list[tuple[dict, list[str]]],
) -> set[str]:
    """Identify rare keywords within this week's matched posts.
    Rare = appears in < RARE_KEYWORD_MAX_FREQ of matched posts."""
    if not week_posts:
        return set()
    kw_counts: dict[str, int] = defaultdict(int)
    for _tw, kws in week_posts:
        for kw in set(kws):
            kw_counts[kw] += 1
    total = len(week_posts)
    rare = {kw for kw, c in kw_counts.items() if c / total < RARE_KEYWORD_MAX_FREQ}
    return rare


def narrative_alert(
    user_id: str,
    week_posts_for_handle: list[tuple[dict, list[str]]],
    rare_kws: set[str],
) -> str | None:
    """If 3+ posts share a (rare_kw, other_kw) pair, return that pair as the
    topic label. Each qualifying post must contain BOTH keywords in the pair;
    this avoids false positives where 3 posts only share the rare keyword but
    differ on every other keyword (which would be "post drift," not narrative)."""
    if len(week_posts_for_handle) < NARRATIVE_MIN_POSTS:
        return None
    pair_counts: dict[tuple[str, str], int] = defaultdict(int)
    for _tw, kws in week_posts_for_handle:
        kwset = set(kws)
        rare_in = kwset & rare_kws
        other_in = kwset - rare_in
        for rkw in rare_in:
            for okw in other_in:
                pair_counts[(rkw, okw)] += 1
    qualifying = [(p, c) for p, c in pair_counts.items()
                  if c >= NARRATIVE_MIN_POSTS]
    if not qualifying:
        return None
    qualifying.sort(key=lambda kv: -kv[1])
    rkw, okw = qualifying[0][0]
    return f"{rkw} + {okw}"


# ─── People page ──────────────────────────────────────────────────────────────


_SLUG_NON_ALNUM = re.compile(r"[^a-z0-9]+")


def slugify(name: str) -> str:
    s = name.lower().strip()
    s = _SLUG_NON_ALNUM.sub("-", s)
    return s.strip("-")


def find_existing_people_page(acct: WatchAccount) -> Path | None:
    """Locate the existing brain people-page for this account. Match by:
      1. exact slug match against acct.name
      2. frontmatter `aliases:` list (containing handle or name)
    Return None if not found (we do NOT auto-create — see adversarial #5 logic)."""
    if not PEOPLE_DIR.is_dir():
        return None
    primary = PEOPLE_DIR / f"{slugify(acct.name)}.md"
    if primary.is_file():
        return primary
    # Slow path: scan frontmatter aliases. Cheap on 460 files at startup.
    handle_l = acct.handle.lower()
    name_l = acct.name.lower()
    for p in PEOPLE_DIR.glob("*.md"):
        try:
            with p.open("r") as f:
                head = f.read(4096)
        except OSError:
            continue
        if not head.startswith("---"):
            continue
        # Bounded frontmatter block.
        end = head.find("\n---", 4)
        if end < 0:
            continue
        fm_block = head[:end].lower()
        # Match only against aliases or @handle, NOT raw substring of name.
        if f"@{handle_l}" in fm_block:
            return p
        # aliases line: aliases: [foo, bar, baz]
        m = re.search(r"^aliases:\s*\[([^\]]*)\]", fm_block, re.MULTILINE)
        if m:
            aliases = {a.strip().strip('"\'') for a in m.group(1).split(",")}
            if handle_l in aliases or name_l in aliases:
                return p
    return None


# ─── Brain page IO ────────────────────────────────────────────────────────────


_YAML_RESERVED_LOWER = {"null", "true", "false", "yes", "no", "on", "off", "~"}
_YAML_NUMERIC_RE = re.compile(r"^[+-]?(\d+\.?\d*|\.\d+)([eE][+-]?\d+)?$|^0[xob][0-9a-fA-F]+$")


def render_frontmatter(fm: dict[str, Any]) -> str:
    out = ["---"]
    for k, v in fm.items():
        if isinstance(v, bool):
            out.append(f"{k}: {'true' if v else 'false'}")
        elif isinstance(v, (int, float)):
            out.append(f"{k}: {v}")
        elif isinstance(v, list):
            out.append(f"{k}: [{', '.join(str(x) for x in v)}]")
        elif v is None or v == "":
            out.append(f"{k}: ")
        else:
            sv = str(v).replace("\n", " ").strip()
            needs_quote = (
                any(c in sv for c in ":#&*!|>%@`")
                or sv.lower() in _YAML_RESERVED_LOWER
                or _YAML_NUMERIC_RE.match(sv) is not None
            )
            if needs_quote:
                sv = '"' + sv.replace('"', '\\"') + '"'
            out.append(f"{k}: {sv}")
    out.append("---")
    return "\n".join(out) + "\n"


def write_signal_page_atomic(
    path: Path,
    fm: dict[str, Any],
    body: str,
) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        with tmp.open("w") as f:
            f.write(render_frontmatter(fm))
            if not body.startswith("\n"):
                f.write("\n")
            f.write(body)
            if not body.endswith("\n"):
                f.write("\n")
        tmp.replace(path)
    except OSError as e:
        try:
            tmp.unlink()
        except OSError:
            pass
        raise XWriteError(f"signal page write {path}: {e}")


_TIMELINE_HEADING_RE = re.compile(r"^##\s+Timeline\b")


def append_to_people_timeline(
    path: Path,
    line: str,
) -> None:
    """Idempotent append to the ## Timeline section. Creates section if missing.
    Recognises headings with trailing text (e.g., "## Timeline (last 30d)").
    Skips matches inside fenced code blocks. If timeline marker is in content
    but no real heading line found, falls back to appending a new section."""
    try:
        content = path.read_text()
    except OSError as e:
        raise XWriteError(f"people-page read {path}: {e}")
    if line.strip() in content:
        return  # idempotent — already present

    lines = content.splitlines(keepends=True)
    out: list[str] = []
    inserted = False
    in_fence = False
    i = 0
    while i < len(lines):
        s = lines[i]
        out.append(s)
        # Track triple-backtick fence state.
        if s.lstrip().startswith("```"):
            in_fence = not in_fence
            i += 1
            continue
        if not inserted and not in_fence and _TIMELINE_HEADING_RE.match(s):
            j = i + 1
            while j < len(lines) and (lines[j].startswith("- ") or lines[j].strip() == ""):
                out.append(lines[j])
                j += 1
            if out and not out[-1].endswith("\n"):
                out[-1] += "\n"
            out.append(line + "\n")
            inserted = True
            i = j
            continue
        i += 1

    if not inserted:
        # No real ## Timeline heading found (or all matches were in code fences).
        # Append a fresh section.
        joined = "".join(out)
        sep = "" if joined.endswith("\n\n") else ("\n" if joined.endswith("\n") else "\n\n")
        new_content = joined + sep + "## Timeline\n\n" + line + "\n"
    else:
        new_content = "".join(out)

    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        tmp.write_text(new_content)
        tmp.replace(path)
    except OSError as e:
        try:
            tmp.unlink()
        except OSError:
            pass
        raise XWriteError(f"people-page write {path}: {e}")


def enqueue_reconcile(record: dict) -> None:
    """When the two-write pattern's second step fails, drop a reconciliation
    file so the next run can retry the people-page append."""
    RECONCILE_DIR.mkdir(parents=True, exist_ok=True)
    fname = f"{record.get('user_id','unknown')}-{record.get('post_id','?')}.json"
    path = RECONCILE_DIR / fname
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(record, indent=2) + "\n")
    tmp.replace(path)


