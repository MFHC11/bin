# ─── Logging / timing ─────────────────────────────────────────────────────────


def _log_jsonl(event: str, **kwargs: Any) -> None:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    rec = {"ts": now_iso(), "event": event, **kwargs}
    try:
        with LOG_PATH.open("a") as f:
            f.write(json.dumps(rec, default=str) + "\n")
    except OSError:
        pass  # never let logging tank the run


def info(msg: str) -> None:
    print(msg, file=sys.stderr, flush=True)


def stdout_contract(line: str) -> None:
    """Structured line that brain-run Phase 7 can parse."""
    print(line, flush=True)


def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def today_iso() -> str:
    return dt.date.today().isoformat()


def parse_iso(s: str) -> dt.datetime:
    return dt.datetime.fromisoformat(s.replace("Z", "+00:00"))


# ─── SSL context (Python.org installer compatibility) ─────────────────────────


def _make_ssl_context() -> ssl.SSLContext:
    candidates: list[str | None] = [
        os.environ.get("SSL_CERT_FILE"),
        os.environ.get("REQUESTS_CA_BUNDLE"),
    ]
    py_etc = Path(sys.prefix) / "etc" / "openssl" / "cert.pem"
    if py_etc.is_file():
        candidates.append(str(py_etc))
    if Path("/etc/ssl/cert.pem").is_file():
        candidates.append("/etc/ssl/cert.pem")
    for c in candidates:
        if c and Path(c).is_file():
            return ssl.create_default_context(cafile=c)
    return ssl.create_default_context()


_SSL_CTX = _make_ssl_context()


# ─── Auth ─────────────────────────────────────────────────────────────────────


def load_bearer_token() -> str:
    """Resolve X_BEARER_TOKEN. Keychain first; ~/.gbrain/secrets.env fallback
    for cron contexts where the keychain is locked."""
    user = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
    if user:
        try:
            r = subprocess.run(
                ["security", "find-generic-password", "-a", user, "-s", "X_BEARER_TOKEN", "-w"],
                capture_output=True, text=True, timeout=5, check=False,
            )
            if r.returncode == 0:
                tok = (r.stdout or "").strip()
                if tok:
                    return tok
        except subprocess.TimeoutExpired:
            pass

    # Cron fallback.
    if SECRETS_ENV_PATH.is_file():
        for line in SECRETS_ENV_PATH.read_text().splitlines():
            line = line.strip()
            if line.startswith("X_BEARER_TOKEN="):
                tok = line.split("=", 1)[1].strip().strip("'\"")
                if tok:
                    return tok

    raise XAuthMissingError(
        "X_BEARER_TOKEN not found.\n"
        "Add to keychain:\n"
        "  security add-generic-password -a \"$USER\" -s X_BEARER_TOKEN -w '<token>'\n"
        "Or to ~/.gbrain/secrets.env for cron contexts:\n"
        "  X_BEARER_TOKEN=<token>"
    )


# ─── HTTP ─────────────────────────────────────────────────────────────────────


@dataclasses.dataclass
class ReadBudget:
    """Per-run cap on number of API reads (not credits — X bills opaquely)."""
    max_reads: int
    used: int = 0

    def consume(self, n: int = 1) -> None:
        self.used += n
        if self.used > self.max_reads:
            raise XReadBudgetExhausted(
                f"hit max-reads cap {self.max_reads} (consumed {self.used})"
            )


@dataclasses.dataclass
class WallClock:
    """Hard wall-clock cap on a single run."""
    started_at: float = dataclasses.field(default_factory=time.monotonic)
    cap_s: float = WALL_CAP_S

    def check(self) -> None:
        if (time.monotonic() - self.started_at) > self.cap_s:
            raise XWallClockExceeded(f"wall clock exceeded {self.cap_s}s")


def x_request(
    method: str,
    path: str,
    token: str,
    body: dict | None = None,
    params: dict | None = None,
    *,
    budget: ReadBudget | None = None,
    wall: WallClock | None = None,
) -> tuple[int, Any]:
    """One X v2 call with typed errors + retry.

    402 CreditsDepleted -> XCreditsDepletedError (no retry, hard stop)
    401 -> XAuthError (no retry)
    429 -> respect x-rate-limit-reset, sleep, retry
    5xx -> exp backoff, retry up to MAX_RETRIES
    """
    url = X_BASE + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    raw_body = json.dumps(body).encode() if body is not None else None
    headers = {
        "Authorization": f"Bearer {token}",
        "Accept": "application/json",
        "User-Agent": "x-ingest/0.1 (+brain)",
    }
    if raw_body is not None:
        headers["Content-Type"] = "application/json"

    if wall:
        wall.check()
    if budget and method == "GET":
        budget.consume(1)

    backoff = 1.0
    last_err = ""
    for attempt in range(1, MAX_RETRIES + 1):
        t0 = time.monotonic()
        req = urllib.request.Request(url, data=raw_body, method=method, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT_S, context=_SSL_CTX) as resp:
                status = resp.status
                payload = resp.read()
                dur_ms = int((time.monotonic() - t0) * 1000)
                _log_jsonl("http", method=method, path=path, status=status,
                           duration_ms=dur_ms, attempt=attempt)
                if not payload:
                    return status, {}
                try:
                    return status, json.loads(payload)
                except json.JSONDecodeError as e:
                    raise XResponseParseError(f"200 OK but unparseable JSON from {path}: {e}")
        except urllib.error.HTTPError as e:
            status = e.code
            try:
                err_body = json.loads(e.read().decode()[:8192])
                err_msg = err_body.get("detail") or err_body.get("title") or str(err_body)[:400]
            except (json.JSONDecodeError, UnicodeDecodeError, AttributeError, OSError):
                err_msg = "<unparseable body>"
            dur_ms = int((time.monotonic() - t0) * 1000)
            _log_jsonl("http", method=method, path=path, status=status,
                       duration_ms=dur_ms, attempt=attempt, error=err_msg)
            if status == 401:
                raise XAuthError(f"401 unauthorised: {err_msg}")
            if status == 402:
                raise XCreditsDepletedError(f"402 credits depleted: {err_msg}")
            if status in (403, 404):
                # 403 = forbidden endpoint, 404 = resource not found. Both terminal.
                raise XServerError(f"{status} {err_msg}")
            if status == 429:
                # Sleep until rate-limit-reset if header present; else backoff.
                reset = e.headers.get("x-rate-limit-reset")
                sleep_s = backoff
                if reset:
                    try:
                        sleep_s = max(1.0, float(reset) - time.time())
                    except ValueError:
                        pass
                sleep_s = min(sleep_s, 120)
                if attempt >= MAX_RETRIES:
                    raise XRateLimitError(f"429 after {MAX_RETRIES} retries")
                info(f"  429 -> sleep {sleep_s:.1f}s (attempt {attempt}/{MAX_RETRIES})")
                if wall:
                    wall.check()
                time.sleep(sleep_s)
                continue
            if 500 <= status < 600:
                if attempt >= MAX_RETRIES:
                    raise XServerError(f"{status} after {MAX_RETRIES} retries: {err_msg}")
                info(f"  {status} -> backoff {backoff:.1f}s (attempt {attempt}/{MAX_RETRIES})")
                time.sleep(backoff)
                backoff = min(backoff * 2, 30)
                continue
            # Any other 4xx is permanent.
            raise XServerError(f"{status}: {err_msg}")
        except (urllib.error.URLError, TimeoutError, OSError) as e:
            last_err = repr(e)
            _log_jsonl("http", method=method, path=path, status=0,
                       attempt=attempt, error=last_err)
            if attempt >= MAX_RETRIES:
                raise XServerError(f"network failure after {MAX_RETRIES}: {last_err}")
            info(f"  network err -> backoff {backoff:.1f}s: {last_err}")
            time.sleep(backoff)
            backoff = min(backoff * 2, 30)
    raise XServerError(f"exhausted retries: {last_err}")


def x_paged(
    path: str,
    token: str,
    params: dict,
    *,
    budget: ReadBudget,
    wall: WallClock,
    page_cap: int = HARD_PAGE_CAP,
    since_id: str | None = None,
) -> Iterator[tuple[dict, dict]]:
    """Iterate paginated results. Yields (tweet_obj, includes_users_by_id).
    `since_id` short-circuits backwards iteration via the pagination_token only
    if the endpoint supports it; otherwise we filter client-side."""
    next_token: str | None = None
    pages = 0
    while True:
        if pages >= page_cap:
            info(f"  hit page cap {page_cap} on {path}; stopping pagination")
            return
        qp = dict(params)
        if next_token:
            qp["pagination_token"] = next_token
        status, data = x_request("GET", path, token, params=qp,
                                 budget=budget, wall=wall)
        if not isinstance(data, dict):
            return
        users_by_id: dict[str, dict] = {}
        for u in (data.get("includes") or {}).get("users", []):
            uid = u.get("id")
            if uid:
                users_by_id[uid] = u
        for tw in data.get("data", []) or []:
            yield tw, users_by_id
        meta = data.get("meta") or {}
        next_token = meta.get("next_token")
        if not next_token:
            return
        pages += 1


# ─── Watchlist config ─────────────────────────────────────────────────────────


@dataclasses.dataclass
class WatchAccount:
    tier: int
    user_id: str
    handle: str
    name: str
    primary_channel: str
    relevance_note: str


@dataclasses.dataclass
class Watchlist:
    list_id: str | None
    accounts: list[WatchAccount]
    raw: dict  # for write-back

    def by_user_id(self) -> dict[str, WatchAccount]:
        return {a.user_id: a for a in self.accounts}

    def by_handle_lower(self) -> dict[str, WatchAccount]:
        return {a.handle.lower(): a for a in self.accounts}


def load_watchlist() -> Watchlist:
    if not CONFIG_PATH.is_file():
        raise XConfigError(f"watchlist config missing: {CONFIG_PATH}")
    try:
        raw = json.loads(CONFIG_PATH.read_text())
    except json.JSONDecodeError as e:
        raise XConfigError(f"watchlist JSON parse: {e}")
    if not isinstance(raw, dict):
        raise XConfigError("watchlist root is not an object")
    if raw.get("schema_version") != 1:
        raise XConfigError(f"unsupported schema_version: {raw.get('schema_version')!r}")
    accts: list[WatchAccount] = []
    seen_ids: set[str] = set()
    for i, a in enumerate(raw.get("accounts", [])):
        try:
            uid = str(a["user_id"])
            if uid in seen_ids:
                raise XConfigError(f"duplicate user_id {uid} in account {i}")
            seen_ids.add(uid)
            tier = int(a["tier"])
            if tier not in (1, 2, 3):
                raise XConfigError(f"invalid tier {tier} in account {i}")
            accts.append(WatchAccount(
                tier=tier,
                user_id=uid,
                handle=str(a["handle"]),
                name=str(a["name"]),
                primary_channel=str(a.get("primary_channel", "x")),
                relevance_note=str(a.get("relevance_note", "")),
            ))
        except KeyError as e:
            raise XConfigError(f"account {i} missing field {e}")
    return Watchlist(
        list_id=raw.get("list_id"),
        accounts=accts,
        raw=raw,
    )


def save_watchlist_list_id(wl: Watchlist, list_id: str) -> None:
    wl.raw["list_id"] = list_id
    tmp = CONFIG_PATH.with_suffix(CONFIG_PATH.suffix + ".tmp")
    tmp.write_text(json.dumps(wl.raw, indent=2) + "\n")
    tmp.replace(CONFIG_PATH)


