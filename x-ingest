# Pre-compiled match patterns: whole-word for single tokens; raw for phrases.
_KW_PATTERNS: list[tuple[str, re.Pattern[str]]] = []
for _kw in THESIS_KEYWORDS:
    _esc = re.escape(_kw)
    if " " in _kw or "-" in _kw or "'" in _kw:
        _pat = re.compile(rf"(?<!\w){_esc}(?!\w)", re.IGNORECASE)
    else:
        _pat = re.compile(rf"\b{_esc}\b", re.IGNORECASE)
    _KW_PATTERNS.append((_kw, _pat))


# ─── Injection defense ────────────────────────────────────────────────────────
# Mirrors attio-ingest; extended with reference-link, HTML-anchor, wikilink
# strips per the 2026-05-20 adversarial review (findings #9 and #1-on-wikilink).
# When attio-ingest is also updated to import from a shared module, this block
# can be extracted; for now both files keep an inline copy.

INJECTION_PATTERNS: list[tuple[re.Pattern[str], str]] = [
    (re.compile(r"<script\b[^>]*>.*?</script>", re.I | re.DOTALL), ""),
    (re.compile(r"<iframe\b[^>]*>.*?</iframe>", re.I | re.DOTALL), ""),
    (re.compile(r"<a\b[^>]*>.*?</a>", re.I | re.DOTALL), ""),  # HTML anchors
    (re.compile(r"<[a-zA-Z][^>]*on[a-z]+\s*=", re.I), "<"),  # inline event handlers
    (re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f]"), ""),  # control chars except \n \t \r
    (re.compile(r"\[\[[^\]]*\]\]"), ""),  # wikilink injection
    (re.compile(r"^\s*\[[^\]]+\]:\s*\S+\s*$", re.MULTILINE), ""),  # ref-style link defs
]
# Image and link patterns handle one level of nested parens; iterated to
# fixpoint by scrub_content for deeper nesting.
IMG_PATTERN = re.compile(r"!\[[^\]]*\]\((?:[^()]*\([^()]*\))*[^()]*\)")
MD_LINK_PATTERN = re.compile(r"\[([^\]]+)\]\((?:[^()]*\([^()]*\))*[^()]*\)")


def scrub_content(s: str) -> str:
    """Strip injection patterns and markdown links from untrusted tweet text.
    Iterates IMG_PATTERN and MD_LINK_PATTERN to a fixpoint (or max 8 iters)
    to handle nested parens without unbounded backtracking on pathological
    inputs."""
    if not s:
        return ""
    for pat, repl in INJECTION_PATTERNS:
        s = pat.sub(repl, s)
    for _ in range(8):
        new = IMG_PATTERN.sub("", s)
        new = MD_LINK_PATTERN.sub(r"\1", new)
        if new == s:
            break
        s = new
    return s


