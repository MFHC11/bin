def run_pass_people(
    people: dict[str, dict],
    idx: PeopleIndex,
    stats: RunStats,
    dry_run: bool,
    author_names: dict[str, str] | None = None,
) -> dict[str, Path]:
    """Returns {record_id: path_to_brain_page}."""
    record_to_path: dict[str, Path] = {}
    for rid, rec in people.items():
        name = extract_person_name(rec)
        emails = extract_person_emails(rec)
        job_title = extract_person_job_title(rec)
        loc = extract_primary_location(rec)
        enrich = extract_person_enrichment(rec)

        if not name and not emails:
            stats.records_skipped_no_name += 1
            continue
        primary_domain = _domain_part(emails[0]) if emails else ""
        is_internal = primary_domain in INTERNAL_TEAM_DOMAINS_FOR_STUB

        existing = find_existing_person(idx, name, emails)
        if existing:
            fm, body = read_page(existing)
            fm = merge_interaction_frontmatter(fm, rec, author_names)
            fm = apply_person_location_frontmatter(fm, loc)
            fm = apply_person_enrichment_frontmatter(fm, enrich)
            new_aliases: list[str] = []
            if name:
                new_aliases.append(name)
            for em in emails:
                lp = _local_part(em)
                if lp:
                    new_aliases.append(lp)
            fm["aliases"] = merge_aliases(fm.get("aliases"), new_aliases)
            if emails and not fm.get("email"):
                fm["email"] = emails[0]
            if not dry_run:
                write_page_atomic(existing, fm, body)
            stats.people_pages_updated += 1
            stats.interaction_metadata_updated += 1
            record_to_path[rid] = existing
            continue

        if is_internal:
            stats.records_skipped_internal += 1
            continue
        if not name:
            stats.records_skipped_no_name += 1
            continue

        slug = slugify(name) or f"attio-{rid[:8]}"
        path = PEOPLE_DIR / f"{slug}.md"
        if path.is_file():
            for n in range(2, 100):
                cand = PEOPLE_DIR / f"{slug}-{n}.md"
                if not cand.is_file():
                    path = cand
                    break
        fm, body = stub_person_page(rec, name, emails, job_title)
        fm = merge_interaction_frontmatter(fm, rec, author_names)
        fm = apply_person_location_frontmatter(fm, loc)
        fm = apply_person_enrichment_frontmatter(fm, enrich)
        if not dry_run:
            write_page_atomic(path, fm, body)
        register_new_path(idx, None, path, name, emails=emails)
        stats.people_pages_created += 1
        stats.interaction_metadata_updated += 1
        record_to_path[rid] = path
    return record_to_path


def run_pass_companies(
    companies: dict[str, dict],
    idx: CompaniesIndex,
    stats: RunStats,
    dry_run: bool,
    author_names: dict[str, str] | None = None,
) -> dict[str, Path]:
    record_to_path: dict[str, Path] = {}
    for rid, rec in companies.items():
        name = extract_company_name(rec)
        domains = extract_company_domains(rec)
        description = extract_company_description(rec)
        loc = extract_primary_location(rec)
        enrich = extract_company_enrichment(rec, domains)
        if not name:
            stats.records_skipped_no_name += 1
            continue

        existing = find_existing_company(idx, name, domains)
        if existing:
            fm, body = read_page(existing)
            fm = merge_interaction_frontmatter(fm, rec, author_names)
            fm = apply_company_location_frontmatter(fm, loc)
            fm = apply_company_enrichment_frontmatter(fm, enrich)
            new_aliases = [name] + list(domains)
            fm["aliases"] = merge_aliases(fm.get("aliases"), new_aliases)
            if not dry_run:
                write_page_atomic(existing, fm, body)
            stats.companies_pages_updated += 1
            stats.interaction_metadata_updated += 1
            record_to_path[rid] = existing
            continue

        slug = slugify(name) or f"attio-{rid[:8]}"
        path = COMPANIES_DIR / f"{slug}.md"
        if path.is_file():
            for n in range(2, 100):
                cand = COMPANIES_DIR / f"{slug}-{n}.md"
                if not cand.is_file():
                    path = cand
                    break
        fm, body = stub_company_page(name, domains, description)
        fm = merge_interaction_frontmatter(fm, rec, author_names)
        fm = apply_company_location_frontmatter(fm, loc)
        fm = apply_company_enrichment_frontmatter(fm, enrich)
        if not dry_run:
            write_page_atomic(path, fm, body)
        register_new_path(None, idx, path, name, domains=domains)
        stats.companies_pages_created += 1
        stats.interaction_metadata_updated += 1
        record_to_path[rid] = path
    return record_to_path


def run_pass_notes(
    key: str,
    record_paths: dict[str, Path],
    parent_object: str,
    author_names: dict[str, str],
    stats: RunStats,
    dry_run: bool,
) -> None:
    for rid, path in record_paths.items():
        try:
            notes = list(attio_paged_notes(key, parent_object, rid))
        except AttioFetchError as e:
            info(f"  notes fetch failed for {parent_object}/{rid[:8]}: {e}")
            continue
        if not notes:
            continue
        fm, body = read_page(path)
        appended = False
        for note in notes:
            note_id = (note.get("id") or {}).get("note_id") or ""
            if not note_id:
                continue
            if note_already_cited(body, note_id):
                stats.notes_skipped_dup += 1
                continue
            line = format_note_timeline_line(note, author_names)
            body = append_to_section(body, "Timeline", line)
            stats.notes_appended += 1
            appended = True
        if appended and not dry_run:
            write_page_atomic(path, fm, body)


