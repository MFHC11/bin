def cmd_self_test(args: argparse.Namespace) -> int:
    loader = unittest.TestLoader()
    suite = loader.loadTestsFromTestCase(_SelfTest)
    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(suite)
    return 0 if result.wasSuccessful() else 1


# ─── CLI ──────────────────────────────────────────────────────────────────────


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="attio-ingest",
        description="Pull Attio CRM data into ~/brain/{people,companies}/.",
    )
    p.add_argument("--full", action="store_true", help="ignore watermark; full re-pull")
    p.add_argument("--dry-run", action="store_true", help="show counts; no writes")
    p.add_argument("--stats", action="store_true", help="record counts only; no writes")
    p.add_argument("--self-test", action="store_true", help="run inline unit tests")
    p.add_argument("--pass", dest="pass_name", choices=["people", "notes", "interactions"],
                   help="run only one pass")
    p.add_argument("--full-org", action="store_true",
                   help="bypass Marcus-only interaction filter (full team CRM)")
    p.add_argument("--enrich-notes", action="store_true",
                   help="(reserved for v2 — Haiku entity extraction; not implemented yet)")
    p.add_argument("--yes-first-run", action="store_true",
                   help="acknowledge that this is the first live run (no watermark exists)")
    p.add_argument("--limit", type=int, default=0, metavar="N",
                   help="stop fetching after N qualifying records per object "
                        "(dry-run/stats sampling; 0=no limit)")
    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    if args.self_test:
        return cmd_self_test(args)
    if args.enrich_notes:
        info("--enrich-notes: deferred to a future Haiku pass; not implemented yet")
        return 64
    try:
        if args.stats:
            return cmd_stats(args)
        return cmd_run(args)
    except AttioAuthMissingError as e:
        info(f"ERROR: {e}")
        return 2
    except (AttioAuthError, AttioScopeError) as e:
        info(f"ERROR (auth): {e}")
        info("  rotate the key or grant the missing scope at Attio workspace settings")
        return 2
    except MarcusNotFoundError as e:
        info(f"ERROR: {e}")
        return 3
    except LockHeldError as e:
        info(f"ERROR: {e}")
        return 5
    except (AttioFetchError, AttioRateLimitError, AttioWriteError, AttioFilterError) as e:
        info(f"ERROR: {e}")
        return 1
    except KeyboardInterrupt:
        info("interrupted")
        return 130


if __name__ == "__main__":
    sys.exit(main())
