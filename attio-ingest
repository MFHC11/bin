# ─── Logging ──────────────────────────────────────────────────────────────────


def _log_jsonl(event: str, **kwargs: Any) -> None:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    rec = {"ts": now_iso(), "event": event, **kwargs}
    try:
        with LOG_PATH.open("a") as f:
            f.write(json.dumps(rec, default=str) + "\n")
    except OSError:
        pass  # never let logging tank the run


def info(msg: str) -> None:
    print(msg, file=sys.stderr, flush=True)


def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def today_iso() -> str:
    return dt.date.today().isoformat()


# ─── SSL ──────────────────────────────────────────────────────────────────────


def _make_ssl_context() -> ssl.SSLContext:
    """Find a usable CA bundle. Python.org Python 3.x on macOS does not trust
    the system keychain by default — without this the script gets
    CERTIFICATE_VERIFY_FAILED. Try (in order): SSL_CERT_FILE env var,
    Python's built-in bundle if Install Certificates.command was run,
    then the macOS LibreSSL bundle at /etc/ssl/cert.pem."""
    candidates: list[str | None] = [
        os.environ.get("SSL_CERT_FILE"),
        os.environ.get("REQUESTS_CA_BUNDLE"),
    ]
    # Python.org installer writes here when Install Certificates.command runs.
    py_etc = Path(sys.prefix) / "etc" / "openssl" / "cert.pem"
    if py_etc.is_file():
        candidates.append(str(py_etc))
    if Path("/etc/ssl/cert.pem").is_file():
        candidates.append("/etc/ssl/cert.pem")
    for c in candidates:
        if c and Path(c).is_file():
            return ssl.create_default_context(cafile=c)
    # Fall through to default — will raise loudly with a clear error if it can't verify.
    return ssl.create_default_context()


_SSL_CTX = _make_ssl_context()


# ─── Keychain ─────────────────────────────────────────────────────────────────


def load_api_key() -> str:
    user = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
    if not user:
        raise AttioAuthMissingError("$USER not set; cannot look up keychain item")
    try:
        r = subprocess.run(
            ["security", "find-generic-password", "-a", user, "-s", "ATTIO_API_KEY", "-w"],
            capture_output=True, text=True, timeout=5, check=False,
        )
    except subprocess.TimeoutExpired:
        raise AttioAuthMissingError("keychain lookup timed out")
    if r.returncode != 0:
        msg = (r.stderr or "").strip() or "ATTIO_API_KEY not in keychain"
        raise AttioAuthMissingError(
            f"{msg}\n"
            "add it with:\n"
            "  security add-generic-password -a \"$USER\" -s ATTIO_API_KEY -w '<your-key>'"
        )
    key = r.stdout.strip()
    if not key:
        raise AttioAuthMissingError("ATTIO_API_KEY is empty in keychain")
    return key


# ─── HTTP ─────────────────────────────────────────────────────────────────────


def attio_request(
    method: str,
    path: str,
    key: str,
    body: dict | None = None,
    params: dict | None = None,
) -> tuple[int, Any]:
    """Make one Attio API call. Handles 429 with Retry-After, exp-backoff 5xx.
    Raises typed errors for auth/scope/rate-limit/server failures. Never
    swallows errors silently."""
    url = ATTIO_BASE + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    raw_body = json.dumps(body).encode() if body is not None else None
    headers = {
        "Authorization": f"Bearer {key}",
        "Accept": "application/json",
    }
    if raw_body is not None:
        headers["Content-Type"] = "application/json"

    backoff = 1.0
    last_err: str = ""
    for attempt in range(1, MAX_RETRIES + 1):
        t0 = time.monotonic()
        req = urllib.request.Request(url, data=raw_body, method=method, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT_S, context=_SSL_CTX) as resp:
                status = resp.status
                payload = resp.read()
                dur_ms = int((time.monotonic() - t0) * 1000)
                _log_jsonl(
                    "http", method=method, path=path, status=status,
                    duration_ms=dur_ms, attempt=attempt,
                )
                if not payload:
                    return status, {}
                try:
                    return status, json.loads(payload)
                except json.JSONDecodeError as e:
                    raise AttioFetchError(
                        f"200 OK but unparseable JSON from {path}: {e}"
                    )
        except urllib.error.HTTPError as e:
            status = e.code
            try:
                err_body = json.loads(e.read().decode()[:8192])
                err_msg = err_body.get("message") or str(err_body)[:400]
            except (json.JSONDecodeError, UnicodeDecodeError, AttributeError, OSError):
                err_msg = "<unparseable body>"
            dur_ms = int((time.monotonic() - t0) * 1000)
            _log_jsonl(
                "http", method=method, path=path, status=status,
                duration_ms=dur_ms, attempt=attempt, error=err_msg,
            )
            if status == 401:
                raise AttioAuthError(f"401 unauthorised: {err_msg}")
            if status == 403:
                raise AttioScopeError(f"403 missing scope: {err_msg}")
            if status == 400 and ("filter" in err_msg.lower() or "attribute" in err_msg.lower()):
                raise AttioFilterError(f"400 filter rejected: {err_msg}")
            if status == 429:
                retry_after = e.headers.get("Retry-After")
                try:
                    sleep_s = float(retry_after) if retry_after else backoff
                except ValueError:
                    sleep_s = backoff
                if attempt >= MAX_RETRIES:
                    raise AttioRateLimitError(f"429 after {MAX_RETRIES} retries: {err_msg}")
                info(f"  429 → sleeping {sleep_s:.1f}s (attempt {attempt}/{MAX_RETRIES})")
                time.sleep(min(sleep_s, 60))
                continue
            if 500 <= status < 600:
                if attempt >= MAX_RETRIES:
                    raise AttioFetchError(f"{status} after {MAX_RETRIES} retries: {err_msg}")
                info(f"  {status} → backoff {backoff:.1f}s (attempt {attempt}/{MAX_RETRIES})")
                time.sleep(backoff)
                backoff = min(backoff * 2, 30)
                continue
            # Any other 4xx is a permanent client error — surface immediately.
            raise AttioFetchError(f"{status}: {err_msg}")
        except (urllib.error.URLError, TimeoutError, OSError) as e:
            last_err = repr(e)
            _log_jsonl(
                "http", method=method, path=path, status=0,
                attempt=attempt, error=last_err,
            )
            if attempt >= MAX_RETRIES:
                raise AttioFetchError(f"network failure after {MAX_RETRIES} attempts: {last_err}")
            info(f"  network err → backoff {backoff:.1f}s (attempt {attempt}/{MAX_RETRIES}): {last_err}")
            time.sleep(backoff)
            backoff = min(backoff * 2, 30)
    raise AttioFetchError(f"exhausted retries: {last_err}")


def attio_paged_records(
    object_slug: str,
    key: str,
    filter_body: dict,
    page_size: int = PAGE_SIZE_RECORDS,
) -> Iterator[dict]:
    """Iterate every record matching the filter, paging via offset.
    Caps at HARD_PAGE_CAP * page_size records as a safety net."""
    offset = 0
    pages = 0
    while True:
        if pages >= HARD_PAGE_CAP:
            raise AttioFetchError(
                f"hit hard page cap of {HARD_PAGE_CAP} pages on /objects/{object_slug}/records/query"
            )
        body = {**filter_body, "limit": page_size, "offset": offset}
        status, data = attio_request(
            "POST", f"/objects/{object_slug}/records/query", key, body=body,
        )
        records = data.get("data", []) if isinstance(data, dict) else []
        for rec in records:
            yield rec
        if len(records) < page_size:
            return
        offset += page_size
        pages += 1


def attio_paged_notes(
    key: str,
    parent_object: str,
    parent_record_id: str,
    page_size: int = PAGE_SIZE_NOTES,
) -> Iterator[dict]:
    offset = 0
    pages = 0
    while True:
        if pages >= HARD_PAGE_CAP:
            raise AttioFetchError(f"hit hard page cap on /notes for {parent_object}/{parent_record_id}")
        params = {
            "parent_object": parent_object,
            "parent_record_id": parent_record_id,
            "limit": page_size,
            "offset": offset,
        }
        status, data = attio_request("GET", "/notes", key, params=params)
        notes = data.get("data", []) if isinstance(data, dict) else []
        for n in notes:
            yield n
        if len(notes) < page_size:
            return
        offset += page_size
        pages += 1


def attio_paged_list_entries(key: str, list_id: str) -> Iterator[dict]:
    offset = 0
    pages = 0
    while True:
        if pages >= HARD_PAGE_CAP:
            raise AttioFetchError(f"hit hard page cap on /lists/{list_id}/entries/query")
        body = {"limit": PAGE_SIZE_RECORDS, "offset": offset}
        status, data = attio_request(
            "POST", f"/lists/{list_id}/entries/query", key, body=body,
        )
        entries = data.get("data", []) if isinstance(data, dict) else []
        for e in entries:
            yield e
        if len(entries) < PAGE_SIZE_RECORDS:
            return
        offset += PAGE_SIZE_RECORDS
        pages += 1


# ─── Bootstrap ────────────────────────────────────────────────────────────────


def resolve_workspace(key: str) -> tuple[str, dict[str, str]]:
    """Returns (MARCUS_MID, {mid: 'First Last'}). Single /workspace_members
    call serves both Marcus identification and note-author display name
    mapping. Falls back to /v2/self if user_management:read is missing —
    in that case the name map is empty (notes will cite by mid)."""
    try:
        status, data = attio_request("GET", "/workspace_members", key)
        members = data.get("data", [])
        name_map: dict[str, str] = {}
        marcus_mid: str | None = None
        for m in members:
            mid = (m.get("id") or {}).get("workspace_member_id")
            if not _is_uuid(mid):
                continue
            fn = (m.get("first_name") or "").strip()
            ln = (m.get("last_name") or "").strip()
            name_map[mid] = (fn + " " + ln).strip() or (m.get("email_address") or mid)
            if (m.get("email_address") or "").lower() == "marcus@erv.io":
                marcus_mid = mid
        if marcus_mid:
            BIN_DIR.mkdir(parents=True, exist_ok=True)
            MARCUS_MID_CACHE.write_text(marcus_mid + "\n")
            return marcus_mid, name_map
        raise MarcusNotFoundError(
            "marcus@erv.io not in workspace_members; check Attio workspace membership"
        )
    except AttioScopeError:
        info("  user_management:read missing → /v2/self fallback (note authors cited by mid)")
        status, data = attio_request("GET", "/self", key)
        mid = data.get("authorized_by_workspace_member_id")
        if not _is_uuid(mid):
            raise MarcusNotFoundError(
                "could not resolve MARCUS_MID from /self either"
            )
        BIN_DIR.mkdir(parents=True, exist_ok=True)
        MARCUS_MID_CACHE.write_text(mid + "\n")
        return mid, {}


_UUID_RE = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", re.I)


def _is_uuid(s: Any) -> bool:
    return isinstance(s, str) and bool(_UUID_RE.match(s))


# ─── Filter construction ──────────────────────────────────────────────────────


def build_interaction_filter(mid: str, since_iso: str | None) -> list[dict]:
    """Return one filter body per interaction-attribute slug we care about.
    Caller queries each separately and unions results by record_id."""
    slugs = ["last_email_interaction", "last_calendar_interaction"]
    bodies: list[dict] = []
    for slug in slugs:
        sub: dict[str, Any] = {"owner_member_id": mid}
        if since_iso:
            sub["interacted_at"] = {"$gte": since_iso}
        bodies.append({"filter": {slug: sub}})
    return bodies


def build_updated_at_filter(mid: str, since_iso: str) -> dict:
    """Try the spec'd top-level updated_at filter. May be rejected by Attio's
    filter validator — caller catches AttioFilterError and falls back."""
    return {
        "filter": {
            "$or": [
                {"last_email_interaction": {"owner_member_id": mid}},
                {"last_calendar_interaction": {"owner_member_id": mid}},
            ],
            "updated_at": {"$gte": since_iso},
        }
    }


def fetch_qualifying_records(
    key: str,
    object_slug: str,
    mid: str,
    since_iso: str | None,
    full_org: bool = False,
    limit: int = 0,
) -> dict[str, dict]:
    """Returns {record_id: record_dict}. Unions:
    (interaction_filter ∪ list_qualified) when not full_org, else everything.

    On delta runs, tries updated_at + interaction first; if Attio rejects,
    drops back to interaction-only filter.

    `limit > 0` stops fetching once that many distinct records are in `out`.
    Used for --dry-run/--stats sampling."""
    out: dict[str, dict] = {}

    def hit_limit() -> bool:
        return limit > 0 and len(out) >= limit

    if full_org:
        info(f"  --full-org: pulling ALL {object_slug} records")
        all_body: dict = {}
        if since_iso:
            try:
                all_body = {"filter": {"updated_at": {"$gte": since_iso}}}
                for rec in attio_paged_records(object_slug, key, all_body):
                    rid = _record_id(rec)
                    if rid:
                        out[rid] = rec
                        if hit_limit(): return out
                return out
            except AttioFilterError:
                info("  updated_at filter rejected; falling back to full pull (delta lost)")
        for rec in attio_paged_records(object_slug, key, {}):
            rid = _record_id(rec)
            if rid:
                out[rid] = rec
                if hit_limit(): return out
        return out

    # Marcus-only path. Try the union filter with updated_at first.
    used_updated_at = False
    if since_iso:
        try:
            for rec in attio_paged_records(
                object_slug, key, build_updated_at_filter(mid, since_iso)
            ):
                rid = _record_id(rec)
                if rid:
                    out[rid] = rec
                    if hit_limit(): return out
            used_updated_at = True
            info(f"  {object_slug}: delta filter using updated_at + interaction; {len(out)} records so far")
        except AttioFilterError as e:
            info(f"  updated_at filter rejected ({e}); falling back to interaction-only delta")

    if not used_updated_at:
        for body in build_interaction_filter(mid, since_iso):
            if hit_limit(): return out
            for rec in attio_paged_records(object_slug, key, body):
                rid = _record_id(rec)
                if rid:
                    out[rid] = rec
                    if hit_limit(): return out

    # List qualification — independent set, unioned in.
    for list_name, list_id, parent in QUALIFYING_LISTS:
        if parent != object_slug:
            continue
        if hit_limit():
            return out
        try:
            ids = set()
            for entry in attio_paged_list_entries(key, list_id):
                rid = entry.get("parent_record_id")
                if rid:
                    ids.add(rid)
            info(f"  {object_slug}: list {list_name!r} contributes {len(ids)} record_id(s)")
            # Fetch any list-qualified records not already in out.
            missing = ids - out.keys()
            for rid in missing:
                if hit_limit():
                    return out
                try:
                    status, data = attio_request(
                        "GET", f"/objects/{object_slug}/records/{rid}", key,
                    )
                    if isinstance(data, dict) and data.get("data"):
                        out[rid] = data["data"]
                except AttioFetchError as e:
                    info(f"    skip list record {rid[:8]}: {e}")
        except AttioScopeError:
            info(f"  list {list_name!r}: no read access (workspace_access=None); skipping")
        except AttioFetchError as e:
            info(f"  list {list_name!r}: fetch failed: {e}")

    return out


def _record_id(rec: dict) -> str | None:
    rid = (rec.get("id") or {}).get("record_id")
    return rid if _is_uuid(rid) else None


# ─── Attio value extraction ───────────────────────────────────────────────────
#
# Attio returns each attribute as an ARRAY of timestamped value objects.
# We want the currently-active value (active_until is null).


def _active_values(rec: dict, slug: str) -> list[dict]:
    arr = (rec.get("values") or {}).get(slug) or []
    return [v for v in arr if v.get("active_until") in (None, "")]


_QUOTES_AND_SPACE = re.compile(r"\s+")


def _clean_name(s: str) -> str:
    """Strip surrounding ASCII / smart quotes, collapse runs of whitespace.
    Attio stores some names with literal embedded quotes (e.g. `'Mats  Blacker'`)
    and stray double spaces — surfaces that as ugly markdown."""
    if not s:
        return ""
    s = s.strip()
    while len(s) >= 2 and s[0] in "\"'‘’“”" and s[-1] in "\"'‘’“”":
        s = s[1:-1].strip()
    return _QUOTES_AND_SPACE.sub(" ", s).strip()


def extract_person_name(rec: dict) -> str:
