# ─── Slug + dedup ─────────────────────────────────────────────────────────────


_SLUG_STRIP = re.compile(r"[^a-z0-9]+")


def slugify(name: str) -> str:
    """Lowercase, ASCII-fold-ish, hyphenated. Matches inbox-enrich convention."""
    if not name:
        return ""
    # Fold a few common diacritics.
    folded = (name.lower()
              .replace("ø", "o").replace("æ", "ae").replace("ß", "ss"))
    import unicodedata
    folded = unicodedata.normalize("NFKD", folded)
    folded = "".join(c for c in folded if not unicodedata.combining(c))
    slug = _SLUG_STRIP.sub("-", folded).strip("-")
    return slug


def _local_part(email: str) -> str:
    return email.split("@", 1)[0].strip().lower() if "@" in email else ""


def _domain_part(email: str) -> str:
    return email.split("@", 1)[1].strip().lower() if "@" in email else ""


# ─── Frontmatter parse / write ────────────────────────────────────────────────
#
# Minimal YAML-ish parser. Brain pages use simple key: value, no nested dicts.
# `aliases:` is a YAML flow array on one line, `tags:` likewise. Anything else
# is a scalar string. This keeps us off PyYAML which would be a new dep.


_FM_DELIM = "---"


def read_page(path: Path) -> tuple[dict[str, Any], str]:
    if not path.is_file():
        return {}, ""
    text = path.read_text()
    if not text.startswith("---\n"):
        return {}, text
    lines = text.splitlines(keepends=True)
    end_idx = None
    for i, ln in enumerate(lines[1:], start=1):
        if ln.rstrip() == "---":
            end_idx = i
            break
    if end_idx is None:
        return {}, text
    fm_raw = "".join(lines[1:end_idx])
    body = "".join(lines[end_idx + 1:])
    return _parse_frontmatter(fm_raw), body


def _parse_frontmatter(raw: str) -> dict[str, Any]:
    out: dict[str, Any] = {}
    for line in raw.splitlines():
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        k = k.strip()
        v = v.strip()
        if v.startswith("[") and v.endswith("]"):
            inner = v[1:-1].strip()
            if not inner:
                out[k] = []
            else:
                out[k] = [_unquote(s.strip()) for s in _split_csv(inner)]
        else:
            out[k] = _unquote(v) if v else ""
    return out


def _split_csv(s: str) -> list[str]:
    """Split on commas not inside quotes."""
    out: list[str] = []
    buf: list[str] = []
    in_quote: str | None = None
    for ch in s:
        if in_quote:
            if ch == in_quote:
                in_quote = None
            buf.append(ch)
        elif ch in ("'", '"'):
            in_quote = ch
            buf.append(ch)
        elif ch == ",":
            out.append("".join(buf))
            buf = []
        else:
            buf.append(ch)
    if buf:
        out.append("".join(buf))
    return out


def _unquote(s: str) -> str:
    if len(s) >= 2 and s[0] == s[-1] and s[0] in ("'", '"'):
        return s[1:-1]
    return s


def _quote_for_yaml(s: str) -> str:
    """Wrap in double quotes if the value would confuse our parser or YAML
    semantics. Leading '-' is the sequence-item gotcha; leading whitespace
    breaks key parsing on re-read."""
    if not s:
        return '""'
    if s[0] in "-?:[{!&*|>'\"" or s != s.lstrip():
        escaped = s.replace("\\", "\\\\").replace('"', '\\"')
        return f'"{escaped}"'
    if any(ch in s for ch in [":", ",", "[", "]", "#", "{", "}", "&", "*", "!", "|", ">", "\"", "'"]):
        escaped = s.replace("\\", "\\\\").replace('"', '\\"')
        return f'"{escaped}"'
    return s


def render_frontmatter(fm: dict[str, Any]) -> str:
    """Render in the order: type, title, created, tags, date, email, aliases,
    location keys, then attio_* fields, then anything else (sorted).
    Matches existing brain page conventions."""
    preferred = [
        # identity
        "type", "title", "created", "tags", "date", "email", "aliases",
        # geography
        "location", "city", "country", "timezone",
        "hq_city", "hq_country",
        # social / contact
        "linkedin", "twitter", "twitter_followers", "phone",
        # company facts
        "website", "employee_range", "founded_year",
        "categories",
        "arr_band", "total_funding_usd",
        # longer text last so it doesn't visually wedge between scalars
        "description",
    ]
    attio_keys = sorted(k for k in fm if k.startswith("attio_"))
    other_keys = sorted(k for k in fm if k not in preferred and k not in attio_keys)
    ordered = [k for k in preferred if k in fm] + attio_keys + other_keys

    out: list[str] = ["---"]
    for k in ordered:
        v = fm[k]
        if isinstance(v, list):
            quoted = ", ".join(_quote_for_yaml(str(x)) for x in v)
            out.append(f"{k}: [{quoted}]")
        elif v == "" or v is None:
            out.append(f"{k}: ")
        else:
            out.append(f"{k}: {_quote_for_yaml(str(v))}")
    out.append("---")
    return "\n".join(out) + "\n"


def write_page_atomic(path: Path, fm: dict[str, Any], body: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        with tmp.open("w") as f:
            f.write(render_frontmatter(fm))
            if not body.startswith("\n"):
                f.write("\n")
            f.write(body)
            if not body.endswith("\n"):
                f.write("\n")
        tmp.replace(path)
    except OSError as e:
        try:
            tmp.unlink()
        except OSError:
            pass
        raise AttioWriteError(f"write to {path}: {e}")


# ─── Existing-page lookup (mechanical dedup) ──────────────────────────────────


@dataclasses.dataclass
class PeopleIndex:
    by_slug: dict[str, Path] = dataclasses.field(default_factory=dict)
    by_email_local: dict[str, Path] = dataclasses.field(default_factory=dict)
    by_alias_lower: dict[str, Path] = dataclasses.field(default_factory=dict)


@dataclasses.dataclass
class CompaniesIndex:
    by_slug: dict[str, Path] = dataclasses.field(default_factory=dict)
    by_domain: dict[str, Path] = dataclasses.field(default_factory=dict)
    by_alias_lower: dict[str, Path] = dataclasses.field(default_factory=dict)


def build_people_index() -> PeopleIndex:
    """Read every people/*.md page once and build O(1) lookup tables.
    Built at run start to avoid O(N×M) disk scans inside the per-record loop."""
    idx = PeopleIndex()
    if not PEOPLE_DIR.is_dir():
        return idx
    for path in PEOPLE_DIR.glob("*.md"):
        idx.by_slug[path.stem] = path
        try:
            fm, _ = read_page(path)
        except OSError:
            continue
        email = (fm.get("email") or "").strip().lower()
        if email and "@" in email:
            lp = _local_part(email)
            if lp:
                idx.by_email_local.setdefault(lp, path)
        aliases = fm.get("aliases") or []
        if isinstance(aliases, list):
            for a in aliases:
                if isinstance(a, str) and a:
                    idx.by_alias_lower.setdefault(a.lower(), path)
    return idx


def build_companies_index() -> CompaniesIndex:
    idx = CompaniesIndex()
    if not COMPANIES_DIR.is_dir():
        return idx
    for path in COMPANIES_DIR.glob("*.md"):
        idx.by_slug[path.stem] = path
        try:
            fm, body = read_page(path)
        except OSError:
            continue
        aliases = fm.get("aliases") or []
        if isinstance(aliases, list):
            for a in aliases:
                if not isinstance(a, str) or not a:
                    continue
                lo = a.lower()
                idx.by_alias_lower.setdefault(lo, path)
                # Aliases often contain domains (mirrored from stub creation).
                if "." in lo and " " not in lo:
                    idx.by_domain.setdefault(lo, path)
    return idx


def find_existing_person(idx: PeopleIndex, name: str, emails: list[str]) -> Path | None:
    """Mechanical dedup per inbox-enrich rule:
       1. exact slug match
       2. email-local-part matches frontmatter `email:`
       3. exact display name in frontmatter `aliases:`
    """
    if name:
        path = idx.by_slug.get(slugify(name))
        if path:
            return path
    for em in emails:
        lp = _local_part(em)
        if lp:
            path = idx.by_email_local.get(lp)
            if path:
                return path
    if name:
        path = idx.by_alias_lower.get(name.lower())
        if path:
            return path
    return None


def find_existing_company(idx: CompaniesIndex, name: str, domains: list[str]) -> Path | None:
    if name:
        ns = slugify(name)
        path = idx.by_slug.get(ns) or idx.by_slug.get(f"lp-{ns}")
        if path:
            return path
    for d in domains:
        path = idx.by_domain.get(d.lower())
        if path:
            return path
    if name:
        path = idx.by_alias_lower.get(name.lower())
        if path:
            return path
    return None


def register_new_path(
    people_idx: PeopleIndex | None,
    companies_idx: CompaniesIndex | None,
    path: Path,
    name: str,
    emails: list[str] | None = None,
    domains: list[str] | None = None,
) -> None:
    """Update the in-memory index when a new stub is created mid-run so a
    second Attio record for the same entity in the same run dedups."""
    if people_idx is not None:
        people_idx.by_slug[path.stem] = path
        if name:
            people_idx.by_alias_lower.setdefault(name.lower(), path)
        for em in emails or []:
            lp = _local_part(em)
            if lp:
                people_idx.by_email_local.setdefault(lp, path)
    if companies_idx is not None:
        companies_idx.by_slug[path.stem] = path
        if name:
            companies_idx.by_alias_lower.setdefault(name.lower(), path)
        for d in domains or []:
            companies_idx.by_domain.setdefault(d.lower(), path)


