    country = loc.get("country_name") or loc.get("country_code")
    if country:
        fm["hq_country"] = country
    return fm


# ─── Generic value extractors for the enrichment attrs ──────────────────────
# Attio attribute_type → JSON shape:
#   text       v["value"] (str)
#   number     v["value"] (int|float)
#   date       v["value"] ("YYYY-MM-DD")
#   select     v["option"]["title"]  (single = first value; multi = each value)
#   phone-number v["phone_number"] (E.164)
#   currency   v["currency_value"] (or v["value"] as a fallback — unverified)


def _text_value(rec: dict, slug: str) -> str:
    for v in _active_values(rec, slug):
        s = (v.get("value") or "").strip() if isinstance(v.get("value"), str) else ""
        if s:
            return s
    return ""


def _number_value(rec: dict, slug: str) -> int | float | None:
    for v in _active_values(rec, slug):
        n = v.get("value")
        if isinstance(n, (int, float)):
            return n
    return None


def _date_value(rec: dict, slug: str) -> str:
    for v in _active_values(rec, slug):
        d = v.get("value")
        if isinstance(d, str) and d:
            return d
    return ""


def _select_value(rec: dict, slug: str) -> str:
    """Return the first option's title."""
    for v in _active_values(rec, slug):
        opt = v.get("option") or {}
        title = opt.get("title")
        if isinstance(title, str) and title:
            return title
    return ""


def _select_multi_values(rec: dict, slug: str) -> list[str]:
    """Return every option's title, preserving Attio's order."""
    out: list[str] = []
    for v in _active_values(rec, slug):
        opt = v.get("option") or {}
        title = opt.get("title")
        if isinstance(title, str) and title and title not in out:
            out.append(title)
    return out


def _phone_value(rec: dict, slug: str = "phone_numbers") -> str:
    for v in _active_values(rec, slug):
        n = (v.get("phone_number") or "").strip()
        if n:
            return n
    return ""


def _currency_value(rec: dict, slug: str) -> int | float | None:
    """Defensive: docs imply v["currency_value"] + v["currency_code"], but no
    populated record was found in the workspace at investigation time. Try
    `currency_value` first, fall back to `value`."""
    for v in _active_values(rec, slug):
        for key in ("currency_value", "value"):
            n = v.get(key)
            if isinstance(n, (int, float)):
                return n
    return None


def extract_person_enrichment(rec: dict) -> dict[str, Any]:
    """Pull every supplementary frontmatter field for a person record.
    Returns only the keys for which Attio has data. Caller passes this
    dict into apply_person_enrichment_frontmatter."""
    out: dict[str, Any] = {}
    li = _text_value(rec, "linkedin")
    if li:
        out["linkedin"] = li
    tw = _text_value(rec, "twitter")
    if tw:
        out["twitter"] = tw
    tw_n = _number_value(rec, "twitter_follower_count")
    if isinstance(tw_n, (int, float)):
        out["twitter_followers"] = int(tw_n)
    ph = _phone_value(rec)
    if ph:
        out["phone"] = ph
    desc = _text_value(rec, "description")
    if desc:
