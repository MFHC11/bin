@dataclasses.dataclass
class RunStats:
    people_pages_created: int = 0
    people_pages_updated: int = 0
    companies_pages_created: int = 0
    companies_pages_updated: int = 0
    notes_appended: int = 0
    notes_skipped_dup: int = 0
    interaction_metadata_updated: int = 0
    records_skipped_no_name: int = 0
    records_skipped_internal: int = 0
    api_calls: int = 0  # informational; logging captures the real number
    started_at: str = dataclasses.field(default_factory=now_iso)

    def as_dict(self) -> dict[str, Any]:
        return dataclasses.asdict(self)


def write_run_summary(stats: RunStats, mode: str, since_iso: str | None) -> Path:
    TASKS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = dt.datetime.now().strftime("%Y-%m-%d-%H%M")
    path = TASKS_DIR / f"attio-run-{stamp}.md"
    lines = [
        f"# Attio ingest — {stamp}",
        "",
        f"- Mode: {mode}",
        f"- Since: {since_iso or '(full pull, no watermark)'}",
        f"- Started: {stats.started_at}",
        f"- Ended:   {now_iso()}",
        "",
        "## Counts",
        "",
        f"- People pages created:    {stats.people_pages_created}",
        f"- People pages updated:    {stats.people_pages_updated}",
        f"- Companies pages created: {stats.companies_pages_created}",
        f"- Companies pages updated: {stats.companies_pages_updated}",
        f"- Notes appended:          {stats.notes_appended}",
        f"- Notes skipped (dup):     {stats.notes_skipped_dup}",
        f"- Interaction frontmatter: {stats.interaction_metadata_updated}",
        f"- Skipped (no name):       {stats.records_skipped_no_name}",
        f"- Skipped (internal team): {stats.records_skipped_internal}",
    ]
    path.write_text("\n".join(lines) + "\n")
    return path


