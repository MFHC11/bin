def cmd_stats(args: argparse.Namespace) -> int:
    key = load_api_key()
    mid, _author_names = resolve_workspace(key)
    info(f"MARCUS_MID = {mid}")

    since_iso = read_watermark() if not args.full else None
    info(f"since = {since_iso or '(full pull)'}")
    info("")

    info("counting people…")
    people = fetch_qualifying_records(key, "people", mid, since_iso, full_org=args.full_org, limit=args.limit)
    info(f"  qualifying people: {len(people)}")

    info("counting companies…")
    companies = fetch_qualifying_records(key, "companies", mid, since_iso, full_org=args.full_org, limit=args.limit)
    info(f"  qualifying companies: {len(companies)}")

    if people:
        sample = next(iter(people.values()))
        info("")
        info("sample person:")
        info(f"  name:    {extract_person_name(sample)}")
        info(f"  emails:  {extract_person_emails(sample)}")
        info(f"  title:   {extract_person_job_title(sample)}")
    if companies:
        sample = next(iter(companies.values()))
        info("")
        info("sample company:")
        info(f"  name:    {extract_company_name(sample)}")
        info(f"  domains: {extract_company_domains(sample)}")

    return 0


def _fetch_and_locate(
    key: str,
    object_slug: str,
    mid: str,
    since_iso: str | None,
    full_org: bool,
    idx: PeopleIndex | CompaniesIndex,
    limit: int = 0,
) -> tuple[dict[str, dict], dict[str, Path]]:
    """Fetch qualifying records and locate paths for those that already
    have brain pages. Used by --pass notes / --pass interactions where we
    don't want to create stubs but still need to know where to write."""
    records = fetch_qualifying_records(key, object_slug, mid, since_iso, full_org=full_org, limit=limit)
    paths: dict[str, Path] = {}
    for rid, rec in records.items():
        if object_slug == "people":
            name = extract_person_name(rec)
            emails = extract_person_emails(rec)
            p = find_existing_person(idx, name, emails) if isinstance(idx, PeopleIndex) else None
        else:
            name = extract_company_name(rec)
            domains = extract_company_domains(rec)
            p = find_existing_company(idx, name, domains) if isinstance(idx, CompaniesIndex) else None
        if p:
            paths[rid] = p
    return records, paths


def cmd_run(args: argparse.Namespace) -> int:
    """Full / delta sync. Honours --dry-run."""
    key = load_api_key()
    mid, author_names = resolve_workspace(key)
    info(f"MARCUS_MID = {mid}  (workspace_members map: {len(author_names)})")
    since_iso = read_watermark() if not args.full else None
    info(f"since = {since_iso or '(full pull)'}  mode = {'dry-run' if args.dry_run else 'LIVE'}")

    if not args.dry_run and not since_iso and not args.full and not args.yes_first_run:
        info("")
        info("first-ever run detected (no watermark). Live writes require --yes-first-run.")
        info("Run --stats first, then --dry-run, then --full --yes-first-run when ready.")
        return 4

    started_at = now_iso()
    stats = RunStats(started_at=started_at)
    summary_path: Path | None = None

    # Build indexes once. O(N) disk read replaces O(N×M) scan inside the
    # per-record loop. Done before the lock guard so that an indexing error
    # surfaces clearly without holding the lock.
    info("building people/companies indexes…")
    people_idx = build_people_index()
    companies_idx = build_companies_index()
    info(f"  people: {len(people_idx.by_slug)} pages | "
         f"companies: {len(companies_idx.by_slug)} pages")

    with acquire_lock(), watermark_guard():
        people: dict[str, dict] = {}
        companies: dict[str, dict] = {}
        people_paths: dict[str, Path] = {}
        company_paths: dict[str, Path] = {}

        run_entities = args.pass_name in (None, "people")
        run_notes = args.pass_name in (None, "notes")
        run_interactions_only = args.pass_name == "interactions"

        if run_entities:
            info("")
            info("─── Pass 1a: People ───")
            people = fetch_qualifying_records(
                key, "people", mid, since_iso, full_org=args.full_org, limit=args.limit,
            )
            info(f"  fetched {len(people)} people")
            people_paths = run_pass_people(people, people_idx, stats, args.dry_run, author_names)

            info("─── Pass 1b: Companies ───")
            companies = fetch_qualifying_records(
                key, "companies", mid, since_iso, full_org=args.full_org, limit=args.limit,
            )
            info(f"  fetched {len(companies)} companies")
            company_paths = run_pass_companies(companies, companies_idx, stats, args.dry_run, author_names)

        if run_notes:
            info("─── Pass 2: Notes ───")
            if not run_entities:
                # Notes-only run: fetch records to know which paths to target,
                # but don't create stubs. Look up paths in the existing index.
                people, people_paths = _fetch_and_locate(
                    key, "people", mid, since_iso, args.full_org, people_idx, limit=args.limit,
                )
                companies, company_paths = _fetch_and_locate(
                    key, "companies", mid, since_iso, args.full_org, companies_idx, limit=args.limit,
                )
                info(f"  located {len(people_paths)}/{len(people)} people pages, "
                     f"{len(company_paths)}/{len(companies)} company pages")
            run_pass_notes(key, people_paths, "people", author_names, stats, args.dry_run)
            run_pass_notes(key, company_paths, "companies", author_names, stats, args.dry_run)

        if run_interactions_only:
            info("─── Pass 3 only: refresh interaction frontmatter ───")
            people, _ = _fetch_and_locate(
                key, "people", mid, since_iso, args.full_org, people_idx, limit=args.limit,
            )
            companies, _ = _fetch_and_locate(
                key, "companies", mid, since_iso, args.full_org, companies_idx, limit=args.limit,
            )
            for rid, rec in people.items():
                name = extract_person_name(rec)
                emails = extract_person_emails(rec)
                p = find_existing_person(people_idx, name, emails)
                if not p:
                    continue
                fm, body = read_page(p)
                fm = merge_interaction_frontmatter(fm, rec, author_names)
                fm = apply_person_location_frontmatter(fm, extract_primary_location(rec))
                fm = apply_person_enrichment_frontmatter(fm, extract_person_enrichment(rec))
                if not args.dry_run:
                    write_page_atomic(p, fm, body)
                stats.interaction_metadata_updated += 1
            for rid, rec in companies.items():
                name = extract_company_name(rec)
                domains = extract_company_domains(rec)
                p = find_existing_company(companies_idx, name, domains)
                if not p:
                    continue
                fm, body = read_page(p)
                fm = merge_interaction_frontmatter(fm, rec, author_names)
                fm = apply_company_location_frontmatter(fm, extract_primary_location(rec))
                fm = apply_company_enrichment_frontmatter(fm, extract_company_enrichment(rec, domains))
                if not args.dry_run:
                    write_page_atomic(p, fm, body)
                stats.interaction_metadata_updated += 1

        if not args.dry_run and args.pass_name is None:
            write_watermark_atomic(now_iso())
            info(f"watermark advanced to {now_iso()}")

        summary_path = write_run_summary(
            stats,
            mode=("dry-run" if args.dry_run else ("full" if args.full else "delta")),
            since_iso=since_iso,
        )

    info("")
    info("── Attio ingest complete ──")
    for k, v in stats.as_dict().items():
        info(f"  {k}: {v}")
    if summary_path:
        info(f"  summary: {summary_path}")
    return 0


def cmd_dry_run(args: argparse.Namespace) -> int:
    args.dry_run = True
    return cmd_run(args)


# ─── Self-test ────────────────────────────────────────────────────────────────


class _SelfTest(unittest.TestCase):
    def test_slugify(self):
        self.assertEqual(slugify("George Vives-Rouco"), "george-vives-rouco")
        self.assertEqual(slugify("Moritz de Chaisemartin"), "moritz-de-chaisemartin")
        self.assertEqual(slugify("Müller GmbH"), "muller-gmbh")
        self.assertEqual(slugify(""), "")

    def test_local_part(self):
        self.assertEqual(_local_part("Foo.Bar@Example.com"), "foo.bar")
        self.assertEqual(_local_part("noemail"), "")

    def test_is_uuid(self):
        self.assertTrue(_is_uuid("bd043199-74d2-467c-9de2-791f0c93daa6"))
        self.assertFalse(_is_uuid("not-a-uuid"))
        self.assertFalse(_is_uuid(None))

    def test_scrub_injection_image_tag(self):
        s = "Hello ![alt](https://evil.com/img.png) world"
        self.assertEqual(scrub_content(s), "Hello  world")

    def test_scrub_injection_external_link(self):
        s = "Click [here](https://evil.com) now"
        self.assertEqual(scrub_content(s), "Click here now")

    def test_scrub_injection_js_link(self):
        s = "Click [text](javascript:alert(1))"
        self.assertEqual(scrub_content(s), "Click text")

    def test_scrub_injection_script_tag(self):
        s = "Hi <script>evil()</script> there"
        self.assertEqual(scrub_content(s), "Hi  there")

    def test_scrub_injection_control_chars(self):
        s = "tab\there\x00null\x07bell\nnewline"
        self.assertEqual(scrub_content(s), "tab\therenullbell\nnewline")

    def test_frontmatter_roundtrip(self):
        fm = {
            "type": "person",
            "title": "Tom Le Page",
            "tags": ["stub", "attio-sourced"],
            "aliases": ["Tom Le Page", "tom.lepage"],
            "email": "tom.lepage@invictawealthsolutions.com",
        }
        rendered = render_frontmatter(fm)
        parsed = _parse_frontmatter(rendered.split("---")[1])
        self.assertEqual(parsed["type"], "person")
        self.assertEqual(parsed["tags"], ["stub", "attio-sourced"])
        self.assertEqual(parsed["aliases"], ["Tom Le Page", "tom.lepage"])
        self.assertEqual(parsed["email"], "tom.lepage@invictawealthsolutions.com")

    def test_quote_for_yaml_special_chars(self):
        self.assertEqual(_quote_for_yaml("hello"), "hello")
        self.assertEqual(_quote_for_yaml("with: colon"), '"with: colon"')
        self.assertEqual(_quote_for_yaml("with, comma"), '"with, comma"')

    def test_csv_split_with_quotes(self):
        result = _split_csv('"Tom Le Page", "Tom", "tom.lepage"')
        self.assertEqual([_unquote(x.strip()) for x in result],
                         ["Tom Le Page", "Tom", "tom.lepage"])

    def test_merge_aliases_dedup(self):
        merged = merge_aliases(["Tom Le Page"], ["tom.lepage", "Tom Le Page"])
        self.assertEqual(merged, ["Tom Le Page", "tom.lepage"])

    def test_active_values_filters_inactive(self):
        rec = {"values": {"name": [
            {"full_name": "Old Name", "active_until": "2024-01-01"},
            {"full_name": "Current Name", "active_until": None},
        ]}}
        self.assertEqual(extract_person_name(rec), "Current Name")

    def test_clean_name_strips_quotes(self):
        self.assertEqual(_clean_name("'Mats Blacker'"), "Mats Blacker")
        self.assertEqual(_clean_name('"Foo Bar"'), "Foo Bar")
        self.assertEqual(_clean_name("‘Smart Quoted’"), "Smart Quoted")
        self.assertEqual(_clean_name("'\"Nested\"'"), "Nested")
        self.assertEqual(_clean_name(""), "")
