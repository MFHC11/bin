def extract_primary_location(rec: dict) -> dict[str, str]:
    """Pull the current value of primary_location and normalise to a flat dict.
    Returns {} if no location data. Keys: locality, region, country_code,
    country_name (resolved from ISO-2). All values are str (never None)."""
    for v in _active_values(rec, "primary_location"):
        if v.get("attribute_type") != "location":
            continue
        locality = (v.get("locality") or "").strip()
        region = (v.get("region") or "").strip()
        country_code = (v.get("country_code") or "").strip()
        if not (locality or region or country_code):
            continue
        return {
            "locality": locality,
            "region": region,
            "country_code": country_code,
            "country_name": country_from_iso(country_code),
        }
    return {}


def format_location_display(loc: dict[str, str]) -> str:
    """Build a 1–2-piece display string from a location dict.
    Examples: 'London, United Kingdom' | 'Somerville' | 'United Kingdom'."""
    if not loc:
        return ""
    city = loc.get("locality") or ""
    country = loc.get("country_name") or loc.get("country_code") or ""
    region = loc.get("region") or ""
    if city and country:
        return f"{city}, {country}"
    if city and region:
        return f"{city}, {region}"
    if city:
        return city
    if region and country:
        return f"{region}, {country}"
    if country:
        return country
    return region


def apply_person_location_frontmatter(fm: dict, loc: dict[str, str]) -> dict:
    """Mutate fm in-place with location fields. Only writes keys where Attio
    has data; absent values do not overwrite existing user-set values.
    timezone is intentionally not written — Attio does not surface it."""
    if not loc:
        return fm
    display = format_location_display(loc)
    if display:
        fm["location"] = display
    if loc.get("locality"):
        fm["city"] = loc["locality"]
    country = loc.get("country_name") or loc.get("country_code")
    if country:
        fm["country"] = country
    return fm


def apply_company_location_frontmatter(fm: dict, loc: dict[str, str]) -> dict:
    if not loc:
