def merge_interaction_frontmatter(
    fm: dict, rec: dict, author_names: dict[str, str] | None = None,
) -> dict:
    """Project Attio's interaction attributes into attio_* frontmatter fields.
    These are metadata, not content — safe to overwrite on every run.
    `author_names` maps workspace_member_id → display name; when present,
    attio_last_owner reads as e.g. "Peter Robson" instead of a UUID. Falls
    back to the raw MID if the mapping is missing or empty."""
    out = dict(fm)
    first_email = extract_interaction(rec, "first_email_interaction")
    first_cal = extract_interaction(rec, "first_calendar_interaction")
    last_email = extract_interaction(rec, "last_email_interaction")
    last_cal = extract_interaction(rec, "last_calendar_interaction")

    candidates_first = [x["at"] for x in (first_email, first_cal) if x]
    candidates_last = [x["at"] for x in (last_email, last_cal) if x]
    if candidates_first:
        out["attio_first_contact"] = min(candidates_first)
    if candidates_last:
        out["attio_last_contact"] = max(candidates_last)
        winner = max(
            [x for x in (last_email, last_cal) if x],
            key=lambda x: x["at"],
        )
        owner_mid = winner.get("owner_mid")
        if owner_mid:
            out["attio_last_owner"] = (author_names or {}).get(owner_mid, owner_mid)

    # Interaction count isn't a top-level attribute — we approximate by
    # counting historical values on the interaction arrays. Attio surfaces
    # active + inactive entries; len() of the array is an upper bound.
    n = 0
    for slug in ("last_email_interaction", "last_calendar_interaction"):
        arr = (rec.get("values") or {}).get(slug) or []
        n += len(arr)
    if n:
        out["attio_interaction_count"] = n

    return out


def merge_aliases(existing: Any, new: list[str]) -> list[str]:
    base = list(existing) if isinstance(existing, list) else []
    base_lower = {str(x).lower() for x in base}
    for item in new:
        if item and item.lower() not in base_lower:
            base.append(item)
            base_lower.add(item.lower())
    return base


def append_to_section(body: str, section: str, line: str) -> str:
    """Append a single line to the named ## section. Creates the section
    immediately before ## Timeline if it doesn't exist, else at EOF."""
    pat = re.compile(rf"^##\s+{re.escape(section)}\s*$", re.M)
    m = pat.search(body)
    if m:
        # Find end of this section = next ## heading, or EOF.
        next_m = re.search(r"^##\s+", body[m.end():], re.M)
        if next_m:
            insert_at = m.end() + next_m.start()
            # Trim trailing whitespace before next section, then insert.
            chunk = body[m.end():insert_at]
            cleaned = chunk.rstrip() + "\n" + line + "\n\n"
            return body[:m.end()] + cleaned + body[insert_at:]
        else:
            trimmed = body.rstrip("\n")
            return trimmed + "\n" + line + "\n"
    # Section absent — create it before Timeline if present.
    tm = re.search(r"^##\s+Timeline\s*$", body, re.M)
    new_section = f"\n## {section}\n\n{line}\n"
    if tm:
        return body[:tm.start()] + new_section + "\n" + body[tm.start():]
    return body.rstrip("\n") + new_section


def note_already_cited(body: str, note_id: str) -> bool:
    return f"attio-note:{note_id}" in body


def format_note_timeline_line(note: dict, author_names: dict[str, str] | None = None) -> str:
    note_id = (note.get("id") or {}).get("note_id") or ""
    created = (note.get("created_at") or "")[:10]
    title = (note.get("title") or "").strip()
    author_id = (note.get("created_by_actor") or {}).get("id") or ""
    author = (author_names or {}).get(author_id) or author_id or "unknown"
    content = note.get("content_plaintext") or note.get("content_markdown") or ""
    content = scrub_content(content)
    snippet = " ".join(content.split())[:200]
    if title:
        summary = f"{title} — {snippet}" if snippet else title
    else:
        summary = snippet or "(empty note)"
    return f"- {created}: {summary} [Source: attio-note:{note_id} {created} ({author})]"


def scrub_content(s: str) -> str:
    """Defence-in-depth: strip image tags, scripts, control chars, then strip
    every markdown link regardless of scheme. Link stripping iterates so
    nested parens (e.g. `[t](javascript:f(1))`) are fully consumed."""
    if not s:
        return ""
    for pat, repl in INJECTION_PATTERNS:
        s = pat.sub(repl, s)
    while True:
        new = MD_LINK_PATTERN.sub(r"\1", s)
        if new == s:
            break
        s = new
    return s


# ─── Watermark ────────────────────────────────────────────────────────────────


def read_watermark() -> str | None:
    if not WATERMARK_PATH.is_file():
        return None
    txt = WATERMARK_PATH.read_text().strip()
    return txt or None


def write_watermark_atomic(ts: str) -> None:
    WATERMARK_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = WATERMARK_PATH.with_suffix(WATERMARK_PATH.suffix + ".tmp")
    tmp.write_text(ts + "\n")
    tmp.replace(WATERMARK_PATH)


@contextmanager
def watermark_guard():
    """Backup watermark before the run; restore on exception. Mirrors
    brain-run's with_watermark_guard."""
    backup: Path | None = None
    if WATERMARK_PATH.is_file():
        backup = WATERMARK_PATH.with_suffix(WATERMARK_PATH.suffix + ".bak")
        backup.write_bytes(WATERMARK_PATH.read_bytes())
    try:
        yield
    except BaseException:
        if backup and backup.is_file():
            backup.replace(WATERMARK_PATH)
            info("  watermark restored to pre-run value (failure)")
        elif WATERMARK_PATH.is_file():
            WATERMARK_PATH.unlink()
            info("  stray watermark removed (failure, no prior value)")
        raise
    else:
        if backup and backup.is_file():
            try:
                backup.unlink()
            except OSError:
                pass


# ─── Lock ─────────────────────────────────────────────────────────────────────


@contextmanager
def acquire_lock():
    BIN_DIR.mkdir(parents=True, exist_ok=True)
    try:
        fd = os.open(str(LOCK_PATH), os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
    except FileExistsError:
        try:
            stale = LOCK_PATH.read_text().strip()
        except OSError:
            stale = "<unreadable>"
        raise LockHeldError(
            f"another attio-ingest is running (lock {LOCK_PATH} held by pid {stale}). "
            "If you're sure no other run is in flight, rm the file."
        )
    try:
        os.write(fd, f"{os.getpid()}\n".encode())
        os.close(fd)
        yield
    finally:
        try:
            LOCK_PATH.unlink()
        except FileNotFoundError:
            pass


