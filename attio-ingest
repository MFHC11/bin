    return out


def extract_company_enrichment(rec: dict, domains: list[str]) -> dict[str, Any]:
    """Pull every supplementary frontmatter field for a company record.
    `domains` is already extracted by extract_company_domains; we use the
    first to synthesize the `website:` field since Attio has no website attr."""
    out: dict[str, Any] = {}

    if domains:
        out["website"] = f"https://{domains[0]}"

    desc = _text_value(rec, "description")
    if desc:
        out["description"] = scrub_content(desc)[:500]

    li = _text_value(rec, "linkedin")
    if li:
        out["linkedin"] = li
    tw = _text_value(rec, "twitter")
    if tw:
        out["twitter"] = tw
    tw_n = _number_value(rec, "twitter_follower_count")
    if isinstance(tw_n, (int, float)):
        out["twitter_followers"] = int(tw_n)

    er = _select_value(rec, "employee_range")
    if er:
        out["employee_range"] = er

    fdate = _date_value(rec, "foundation_date")
    if fdate and len(fdate) >= 4:
        # YYYY-MM-DD → year only. Validate the 4-char prefix is digits.
        year = fdate[:4]
        if year.isdigit():
            out["founded_year"] = int(year)

    cats = _select_multi_values(rec, "categories")
    if cats:
        # Attio's category enrichment is multi-select and often noisy. We
        # surface the raw list and skip a single-pick `industry:` — Marcus
        # reads the categories himself.
        out["categories"] = cats

    arr = _select_value(rec, "estimated_arr_usd")
    if arr:
        out["arr_band"] = arr

    funding = _currency_value(rec, "funding_raised_usd")
    if isinstance(funding, (int, float)):
        out["total_funding_usd"] = funding

    return out


